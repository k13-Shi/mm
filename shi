-- [ 2. HOME TAB ]
Home:NewSection("🟣 K13 PREMIUM VIOLET 🟣")
Home:NewSection("STATUS: ALL TABS VISIBLE")

-- [ 3. FARM TAB ]
local FarmSection = Farm:NewSection("Turbo Farming")
FarmSection:NewToggle("8-PACK SPEED", "Fast Reps", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool then LP.Character.Humanoid:EquipTool(tool) end
            pcall(function() LP.muscleEvent:FireServer("rep") end)
            task.wait()
        end
    end)
end)

-- [ 4. COMBAT TAB - BINABALIK KO YUNG DROPDOWN MO ]
local CombatSection = Combat:NewSection("Player Kill System")

local function getPlayers()
    local p = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer then table.insert(p, v.Name) end
    end
    return p
end

local TargetDropdown = CombatSection:NewDropdown("Select Player", "Target", getPlayers(), function(v)
    getgenv().SelectedPlayer = v
end)

CombatSection:NewButton("🔄 Refresh Player List", "Update Names", function()
    TargetDropdown:Refresh(getPlayers())
end)

CombatSection:NewToggle("💀 KILL ALL (NO TELEPORT)", "Sapak kahit malayo", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            local LP = game.Players.LocalPlayer
            local punch = LP.Backpack:FindFirstChild("Punch") or LP.Character:FindFirstChild("Punch")
            if punch then LP.Character.Humanoid:EquipTool(punch) end
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= LP and v.Character then
                    pcall(function() LP.muscleEvent:FireServer("punchClick", v.Character) end)
                end
            end
            task.wait(0.1)
        end
    end)
end)

-- [ 5. AUTO HATCH/SPIN FIX ]
local PetSection = Pets:NewSection("Crystal Hatching")

PetSection:NewDropdown("Select Crystal", "Pili ka Crystal", {"Common Crystal", "Rare Crystal", "Epic Crystal", "Legendary Crystal", "Abyss Crystal"}, function(v)
    getgenv().SelectedCrystal = v
end)

PetSection:NewToggle("Auto Hatch (SINGLE)", "Dapat may Gems ka!", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local crys = getgenv().SelectedCrystal or "Common Crystal"
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", crys, "single") 
            end)
            task.wait(0.5) 
        end
    end)
end)

PetSection:NewToggle("Auto Spin Wheel", "Awtomatikong Spin", function(state)
    getgenv().AutoSpin = state
    task.spawn(function()
        while getgenv().AutoSpin do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.wheelEvent:FireServer("spinWheel") 
            end)
            task.wait(5)
        end
    end)
end)

