local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥 (FINAL FIX)", "GrapeTheme")

-- [ TABS ]
local Home = Window:NewTab("K13 Home")
local Farm = Window:NewTab("Farm")
local Combat = Window:NewTab("Combat")
local Pets = Window:NewTab("Auto Hatch/Spin")
local Settings = Window:NewTab("Settings")

-- [ HOME ]
Home:NewSection("🟣 K13 PREMIUM VIOLET 🟣")
Home:NewSection("STATUS: AUTO-HATCH & SPIN FIXED")

-- [ FARM ]
local FarmSection = Farm:NewSection("Turbo Farming")
FarmSection:NewToggle("8-PACK SPEED", "Fast Reps", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool then LP.Character.Humanoid:EquipTool(tool) end
            pcall(function() LP.muscleEvent:FireServer("rep") end)
            task.wait()
        end
    end)
end)

FarmSection:NewToggle("Anti-AFK + Timer", "No Kick", function(state)
    getgenv().AntiAFK = state
    _G.AfkFrame.Visible = state
end)

-- [ COMBAT - FAR REACH FIXED ]
local CombatSection = Combat:NewSection("Player Kill System")

CombatSection:NewToggle("💀 KILL ALL (NO TELEPORT)", "Sapak sa malayo", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            local LP = game.Players.LocalPlayer
            local punch = LP.Backpack:FindFirstChild("Punch") or LP.Character:FindFirstChild("Punch")
            if punch then LP.Character.Humanoid:EquipTool(punch) end
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= LP and v.Character then
                    pcall(function() LP.muscleEvent:FireServer("punchClick", v.Character) end)
                end
            end
            task.wait(0.1)
        end
    end)
end)

-- [ AUTO HATCH & SPIN - ITO ANG FIX ]
local PetSection = Pets:NewSection("Auto Pet & Spin Fix")

PetSection:NewDropdown("Select Crystal", "Pili ka dito", {"Common Crystal", "Rare Crystal", "Epic Crystal", "Legendary Crystal", "Abyss Crystal"}, function(v)
    getgenv().SelectedCrystal = v
end)

PetSection:NewToggle("Auto Hatch (Triple)", "Bibiling kusa", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local crys = getgenv().SelectedCrystal or "Common Crystal"
            -- Muscle Masters Remote Path Fix
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", crys, "triple") 
            end)
            task.wait(0.2)
        end
    end)
end)

PetSection:NewToggle("Auto Spin Wheel", "Awtomatikong Spin", function(state)
    getgenv().AutoSpin = state
    task.spawn(function()
        while getgenv().AutoSpin do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.wheelEvent:FireServer("spinWheel") 
            end)
            task.wait(5)
        end
    end)
end)

