RunService.RenderStepped:Connect(function()
    if active.View and viewTarget and viewTarget.Character and viewTarget.Character:FindFirstChild("Humanoid") then
        workspace.CurrentCamera.CameraSubject = viewTarget.Character.Humanoid
    else
        if LP.Character and LP.Character:FindFirstChild("Humanoid") then
            workspace.CurrentCamera.CameraSubject = LP.Character.Humanoid
        end
    end
    if active.KillAll then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if (LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude < 25 then
                    ReplicatedStorage.RemotesEvent.PunchEvent:FireServer()
                end
            end
        end
    end
    if active.TargetKill and targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        if (LP.Character.HumanoidRootPart.Position - targetPlayer.Character.HumanoidRootPart.Position).Magnitude < 25 then
            ReplicatedStorage.RemotesEvent.PunchEvent:FireServer()
        end
    end
end)

