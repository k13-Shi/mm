local Misc = Window:CreateTab("Settings", 4483362458)

local function getRemote(name)
    local rFolder = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents")
    if rFolder then
        for _, v in pairs(rFolder:GetChildren()) do
            if v.Name:lower():find(name:lower()) then
                return v
            end
        end
    end
    return nil
end

Main:CreateSection("Training & Rebirth")

Main:CreateToggle({
   Name = "Fast Farm (Reps)",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
      getgenv().AutoFarm = Value
      task.spawn(function()
         while getgenv().AutoFarm do
            local repRemote = getRemote("rep")
