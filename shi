-- [ FARM TAB ]
local FarmSection = Farm:NewSection("8-Pack Turbo Farm")
FarmSection:NewToggle("8-PACK SPEED", "Fast Reps + Auto Equip", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool and LP.Character then LP.Character.Humanoid:EquipTool(tool) end
            local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
            if Remote then for i = 1, 25 do pcall(function() Remote:FireServer("rep") end) end end
            task.wait(0.001)
        end
    end)
end)

FarmSection:NewToggle("Instant Rebirth", "No delay", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") end)
            task.wait(0.1)
        end
    end)
end)

-- [ ANTI-AFK MINI UI WITH SECONDS ]
local CoreGui = game:GetService("CoreGui")
local AfkGui = Instance.new("ScreenGui", CoreGui)
AfkGui.Name = "K13_AFK_Timer"

local AfkFrame = Instance.new("Frame", AfkGui)
AfkFrame.Size = UDim2.new(0, 120, 0, 50)
AfkFrame.Position = UDim2.new(0, 15, 0.5, 80) -- Nsa gilid sa ilalim ng logo
AfkFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
AfkFrame.Visible = false
AfkFrame.Draggable = true
Instance.new("UICorner", AfkFrame)
local AfkStroke = Instance.new("UIStroke", AfkFrame)
AfkStroke.Color = Color3.fromRGB(138, 43, 226)
AfkStroke.Thickness = 2

local AfkText = Instance.new("TextLabel", AfkFrame)
AfkText.Size = UDim2.new(1, 0, 1, 0)
AfkText.BackgroundTransparency = 1
AfkText.Text = "AFK: 0s"
AfkText.TextColor3 = Color3.fromRGB(138, 43, 226)
AfkText.Font = Enum.Font.GothamBold
AfkText.TextSize = 14

local seconds = 0
task.spawn(function()
    while task.wait(1) do
        if getgenv().AntiAFK then
            seconds = seconds + 1
            AfkText.Text = "AFK: " .. seconds .. "s"
        else
            seconds = 0
        end
    end
end)

Farm:NewSection("Safety"):NewToggle("Anti-AFK (With Timer)", "Stay online 24/7", function(state)
    getgenv().AntiAFK = state
    AfkFrame.Visible = state
end)

-- [ COMBAT TAB ]
local CombatSection = Combat:NewSection("Kill & View (No TP)")
CombatSection:NewToggle("💀 KILL ALL (NO TELEPORT)", "Instant kill everyone", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            local LP = game.Players.LocalPlayer
            local punch = LP.Backpack:FindFirstChild("Punch") or LP.Character:FindFirstChild("Punch")
            if punch and not LP.Character:FindFirstChild("Punch") then LP.Character.Humanoid:EquipTool(punch) end
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= LP and v.Character then
                    pcall(function()
                        LP.muscleEvent:FireServer("punchClick", v.Character)
                        LP.muscleEvent:FireServer("rep", v.Character)
                    end)
                end
            end
            task.wait(0.1)
        end
    end)
end)

