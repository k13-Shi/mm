local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", "GrapeTheme")

-- 1. HOME TAB
local Home = Window:NewTab("K13 Home")
local HomeSection = Home:NewSection("🟣 K13 PREMIUM VIOLET 🟣")
HomeSection:NewLabel("STATUS: NO-ANIMATION KILL ACTIVE")

-- 2. FARM TAB
local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("8-Pack Turbo Farm")

FarmSection:NewToggle("8-PACK SPEED (NO ANIM)", "Fast Reps No Animation", function(state)
    getgenv().AutoFarm = state
    if state then
        task.spawn(function()
            while getgenv().AutoFarm do
                local Remote = game.Players.LocalPlayer:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                if Remote then
                    for i = 1, 20 do -- Mas mabilis na batch
                        pcall(function() Remote:FireServer("rep") end)
                    end
                end
                task.wait(0.001) -- Minimum delay for God Speed
            end
        end)
    end
end)

-- 3. COMBAT TAB (NO-TELEPORT KILL)
local Combat = Window:NewTab("Combat")
local CombatSection = Combat:NewSection("Kill Aura & No-Anim Combat")

local PlayerList = {}
local function getPlayers()
    PlayerList = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer then
            table.insert(PlayerList, v.Name)
        end
    end
    return PlayerList
end

local TargetDropdown = CombatSection:NewDropdown("Select Target Player", "Sino ang pababagsakin?", getPlayers(), function(v)
    getgenv().SelectedPlayer = v
end)

CombatSection:NewButton("🔄 Refresh Player List", "Update names", function()
    TargetDropdown:Refresh(getPlayers())
end)

CombatSection:NewToggle("☣️ Auto Toxic Message", "Chat L when they die", function(state)
    getgenv().AutoToxic = state
end)

-- KILL LOGIC (NO ANIMATION / NO TELEPORT)
CombatSection:NewToggle("💀 INSTANT KILL AURA", "Papatayin lahat ng malapit sa'yo", function(state)
    getgenv().KillAura = state
    task.spawn(function()
        while getgenv().KillAura do
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
                    if dist < 20 then -- Range ng aura (20 studs)
                        -- Remote Spam (Damage without animation)
                        for i = 1, 10 do
                            game:GetService("Players").LocalPlayer.muscleEvent:FireServer("rep", v.Character)
                        end
                        if v.Character.Humanoid.Health <= 0 and getgenv().AutoToxic then
                            game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer("K13 OWNED YOU. EZ.", "All")
                            task.wait(1)
                        end
                    end
                end
            end
            task.wait()
        end
    end)
end)

CombatSection:NewToggle("👁️ View Player", "Stalk target", function(state)
    getgenv().ViewPlayer = state
    task.spawn(function()
        while getgenv().ViewPlayer do
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character then
                workspace.CurrentCamera.CameraSubject = target.Character.Humanoid
            end
            task.wait(0.1)
        end
        workspace.CurrentCamera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
    end)
end)

-- 4. AUTO HATCH
local Pets = Window:NewTab("Auto Hatch")
Pets:NewSection("Abyss Hatching"):NewToggle("Start Hatching", "Hatch Triple", function(state)
