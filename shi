local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "K13 MUSCLE MASTERS 🔥",
   LoadingTitle = "REMOTE OVERDRIVE",
   LoadingSubtitle = "No Clicks | Direct Server Fire",
   ConfigurationSaving = { Enabled = false }
})

local Main = Window:CreateTab("Auto Farm", 4483362458)
local Eggs = Window:CreateTab("Auto Hatch", 4483362458)
local Misc = Window:CreateTab("Settings", 4483362458)

local rEvents = game:GetService("ReplicatedStorage"):WaitForChild("rEvents")

Main:CreateSection("Silent Training")

Main:CreateToggle({
   Name = "Silent Fast Farm (No Click)",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
      getgenv().AutoFarm = Value
      task.spawn(function()
         while getgenv().AutoFarm do
            pcall(function()
               rEvents.repRemote:FireServer("rep")
            end)
            task.wait()
         end
      end)
   end,
})

Main:CreateToggle({
   Name = "Instant Rebirth",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      getgenv().AutoRebirth = Value
      task.spawn(function()
         while getgenv().AutoRebirth do
            pcall(function()
               rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            end)
            task.wait(0.5)
         end
      end)
   end,
})

Eggs:CreateSection("Direct Hatching")

local SelectedEgg = "Common"
Eggs:CreateDropdown({
   Name = "Select Egg",
   Options = {"Common", "Rare", "Epic", "Legendary", "Mythic"},
   CurrentOption = {"Common"},
   Flag = "EggRarity",
   Callback = function(Option) SelectedEgg = Option[1] end,
})

Eggs:CreateToggle({
   Name = "Silent Hatch",
   CurrentValue = false,
   Flag = "AutoHatch",
   Callback = function(Value)
      getgenv().AutoHatch = Value
      task.spawn(function()
         while getgenv().AutoHatch do
            pcall(function()
               rEvents.eggRemote:InvokeServer("openEgg", SelectedEgg)
            end)
            task.wait(0.1)
         end
      end)
   end,
})

Eggs:CreateToggle({
   Name = "Silent Spin",
   CurrentValue = false,
   Flag = "AutoSpin",
   Callback = function(Value)
      getgenv().AutoSpin = Value
      task.spawn(function()
         while getgenv().AutoSpin do
            pcall(function()
               rEvents.wheelEvent:FireServer("spinWheel")
            end)
            task.wait(5)
         end
      end)
   end,
})

Misc:CreateSection("Anti-DC")

Misc:CreateToggle({
   Name = "Anti-AFK",
   CurrentValue = true,
   Flag = "AntiAFK",
   Callback = function(Value) getgenv().AntiAFK = Value end,
})

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)
