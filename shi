local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()

local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", {
    main = Color3.fromRGB(138, 43, 226),
    accent = Color3.fromRGB(138, 43, 226),
    onhover = Color3.fromRGB(160, 60, 255),
    topbar = Color3.fromRGB(138, 43, 226),
    draggable = true
})

local Main = Window:NewTab("K13 Home")
local Farm = Window:NewTab("Farm")
local Settings = Window:NewTab("Settings")

Main:NewSection("K13 PREMIUM")
Main:NewSection("STATUS: ACTIVE")

local FarmSection = Farm:NewSection("Farming")

FarmSection:NewToggle("Fast Farm", "Pinakamabilis na Reps (Stay Mode)", function(state)
    getgenv().AutoFarm = state
    if state then
        task.spawn(function()
            while getgenv().AutoFarm do
                local LP = game.Players.LocalPlayer
                local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                if Remote then
                    for i = 1, 15 do 
                        pcall(function() Remote:FireServer("rep") end)
                    end
                end
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, true, game, 0)
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, false, game, 0)
                task.wait(0.001)
            end
        end)
    end
end)

FarmSection:NewToggle("Instant Rebirth", "Auto Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") end)
            task.wait(0.1)
        end
    end)
end)

FarmSection:NewToggle("Auto Spin", "Awtomatikong Spin", function(state)
    getgenv().AutoSpin = state
    task.spawn(function()
        while getgenv().AutoSpin do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.wheelEvent:FireServer("spinWheel") end)
            task.wait(5)
        end
    end)
end)

local CoreGui = game:GetService("CoreGui")
if CoreGui:FindFirstChild("K13_Violet_Logo") then CoreGui:FindFirstChild("K13_Violet_Logo"):Destroy() end

local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "K13_Violet_Logo"

local K13Button = Instance.new("ImageButton", ScreenGui)
K13Button.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
K13Button.Position = UDim2.new(0, 15, 0.5, 0)
K13Button.Size = UDim2.new(0, 60, 0, 60)
K13Button.Image = "rbxassetid://6031097225"
K13Button.Draggable = true
Instance.new("UICorner", K13Button).CornerRadius = UDim.new(0, 15)

local TimerLabel = Instance.new("TextLabel", K13Button)
TimerLabel.Size = UDim2.new(0, 100, 0, 20)
TimerLabel.Position = UDim2.new(1, 10, 0.3, 0)
TimerLabel.BackgroundTransparency = 1
TimerLabel.TextColor3 = Color3.fromRGB(180, 100, 255)
TimerLabel.Text = "AFK: 0s"
TimerLabel.Font = Enum.Font.GothamBold
TimerLabel.TextSize = 16
TimerLabel.Visible = false

local afkSec = 0
task.spawn(function()
    while task.wait(1) do
        if getgenv().AntiAFK then
            afkSec = afkSec + 1
            TimerLabel.Text = "AFK: "..afkSec.."s"
        else
            afkSec = 0
        end
    end
end)

K13Button.MouseButton1Click:Connect(function() Library:ToggleUI() end)

FarmSection:NewToggle("Anti-AFK + Timer", "Stay Online", function(state)
    getgenv().AntiAFK = state
    TimerLabel.Visible = state
end)

task.spawn(function()
    while task.wait(0.5) do
        for _, v in pairs(CoreGui:GetDescendants()) do
            if v:IsA("ImageButton") and (v.Parent.Name == "Kavo-UI" or v.Name:find("Toggle")) then
                v.Visible = false
            end
        end
    end
end)

Settings:NewSection("Controls"):NewKeybind("Toggle UI", "RightControl", Enum.KeyCode.RightControl, function()
    Library:ToggleUI()
end)

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)
