local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()

local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", {
    main = Color3.fromRGB(138, 43, 226),
    accent = Color3.fromRGB(138, 43, 226),
    onhover = Color3.fromRGB(160, 60, 255),
    topbar = Color3.fromRGB(138, 43, 226),
    draggable = true
})

local Main = Window:NewTab("K13 Home")
local Farm = Window:NewTab("Farm")
local Settings = Window:NewTab("Settings")

Main:NewSection("K13 PREMIUM")
Main:NewSection("STATUS: ACTIVE")

local FarmSection = Farm:NewSection("Farming & Rebirth")

-- [ AUTO FARM ]
FarmSection:NewToggle("Fast Farm", "Auto Clicker/Reps", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local Remote = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote")
            if Remote then
                for i = 1, 10 do 
                    Remote:FireServer("rep")
                end
            end
            task.wait(0.01)
        end
    end)
end)

-- [ FAST REBIRTH ]
FarmSection:NewToggle("Fast Rebirth", "Auto Rebirth (Instant)", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") 
            end)
            task.wait(0.5)
        end
    end)
end)

local EggSection = Farm:NewSection("Auto Hatch & Spin")

-- [ AUTO SPIN ]
EggSection:NewToggle("Auto Spin", "Awtomatikong Spin sa Wheel", function(state)
    getgenv().AutoSpin = state
    task.spawn(function()
        while getgenv().AutoSpin do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.wheelEvent:FireServer("spinWheel") 
            end)
            task.wait(5)
        end
    end)
end)

-- [ AUTO HATCH LOGIC ]
local SelectedEgg = "Common" -- Default
EggSection:NewDropdown("Select Egg Rarity", "Pili ka ng rarity na i-hahatch", {"Common", "Rare", "Epic", "Legendary", "Mythic"}, function(current)
    SelectedEgg = current
end)

EggSection:NewToggle("Auto Hatch", "Auto Open Eggs", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            -- Tandaan: Siguraduhin na tama ang path ng 'openEgg' remote sa game na nilalaro mo.
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.eggRemote:InvokeServer("openEgg", SelectedEgg)
            end)
            task.wait(1)
        end
    end)
end)

