local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", "DarkTheme")

-- MAIN TAB WITH LOGO
local Main = Window:NewTab("K13 Home")
local MainSection = Main:NewSection("K13 PREMIUM VIOLET")
MainSection:NewLabel("🟣 K13 EXCLUSIVE - GOD SPEED 🟣")

-- FARM TAB (8-PACK SPEED)
local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("God Speed Farming")

FarmSection:NewToggle("8-PACK AUTO LIFT (0.01s)", "Sunod-sunod na reps parang Muscle Legends", function(state)
    getgenv().AutoFarm = state
    if state then
        -- Quad-Threaded Spam (4 sabay-sabay na loops para sa 0.01 speed)
        for i = 1, 4 do
            task.spawn(function()
                while getgenv().AutoFarm do
                    local remote = game.Players.LocalPlayer:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                    if remote then
                        if remote.ClassName == "RemoteEvent" then
                            remote:FireServer("rep")
                        else
                            remote:InvokeServer("rep")
                        end
                    end
                    game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, false, game, 0)
                    task.wait(0.01) -- Ang bilis na gusto mo
                end
            end)
        end
    end
end)

FarmSection:NewToggle("Instant Rebirth", "No delay rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            end)
            task.wait(0.01)
        end
    end)
end)

-- PETS TAB (WITH CHOICES)
local Pets = Window:NewTab("Auto Hatch")
local PetSection = Pets:NewSection("Egg Hatching")

PetSection:NewDropdown("Select Egg", "Pili ka ng egg na i-hahatch", {"Abyss Egg", "Common Egg", "Rare Egg", "Legendary Egg"}, function(v)
    getgenv().SelectedEgg = v
end)

PetSection:NewToggle("Start Auto Hatch", "Spam hatch selected egg", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local egg = getgenv().SelectedEgg or "Abyss Egg"
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", egg, "triple")
            end)
            task.wait(0.01)
        end
    end)
end)

