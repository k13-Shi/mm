-- Toggle Creator
local function CreateToggle(parent, text)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 45)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = "  " .. text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 14
    btn.TextXAlignment = Enum.TextXAlignment.Left

    local check = Instance.new("Frame", frame)
    check.Size = UDim2.new(0, 20, 0, 20)
    check.Position = UDim2.new(0.95, -25, 0.5, -10)
    check.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    Instance.new("UICorner", check).CornerRadius = UDim.new(0, 4)

    local inner = Instance.new("Frame", check)
    inner.Size = UDim2.new(0, 0, 0, 0)
    inner.Position = UDim2.new(0.5, 0, 0.5, 0)
    inner.AnchorPoint = Vector2.new(0.5, 0.5)
    inner.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
    Instance.new("UICorner", inner).CornerRadius = UDim.new(0, 3)

    return btn, inner
end

-- Create Toggles
local btnFarm, dotFarm = CreateToggle(MainTab, "Auto Strength")
local btnRebirth, dotRebirth = CreateToggle(MainTab, "Auto Rebirth")

local btnSpin, dotSpin = CreateToggle(MiscTab, "Auto Spin")
local btnAFK, dotAFK = CreateToggle(MiscTab, "Anti-AFK")

-- Logic Flags
local flags = { Farm = false, Rebirth = false, Spin = false, AFK = false }

local function toggleAnim(dot, bool)
    dot:TweenSize(bool and UDim2.new(0.7, 0, 0.7, 0) or UDim2.new(0, 0, 0, 0), "Out", "Back", 0.1)
end

-- Connections
btnFarm.MouseButton1Click:Connect(function() flags.Farm = not flags.Farm; toggleAnim(dotFarm, flags.Farm) end)
btnRebirth.MouseButton1Click:Connect(function() flags.Rebirth = not flags.Rebirth; toggleAnim(dotRebirth, flags.Rebirth) end)
btnSpin.MouseButton1Click:Connect(function() flags.Spin = not flags.Spin; toggleAnim(dotSpin, flags.Spin) end)
btnAFK.MouseButton1Click:Connect(function() 
    flags.AFK = not flags.AFK; toggleAnim(dotAFK, flags.AFK)
    if flags.AFK then loadstring(game:HttpGet("https://pastebin.com/raw/r37Ct26d", true))() end
end)

-- Main Loop Logic
task.spawn(function()
    while true do
        task.wait(0.1)
        if flags.Spin then game.ReplicatedStorage.RemotesEvent.SpinFunction:InvokeServer() end
        if flags.Rebirth then game.ReplicatedStorage.RemotesEvent.RebirthEvent:FireServer() end
        if flags.Farm then
            local machineuse = game.Players.LocalPlayer:WaitForChild("Machineuse")
            if machineuse.Value == nil then
                game.ReplicatedStorage.RemotesEvent.MachineActiveFunction:InvokeServer(game.Workspace.MachinesFolder["Bench Press Muscle Emperor"], true)
            else
                game.ReplicatedStorage.RemotesEvent.MachineActiveEvent:FireServer()
            end
        end
    end
end)

