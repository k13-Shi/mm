-- Wait for game to load
if not game:IsLoaded() then game.Loaded:Wait() end

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()

local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", "VapeTheme") -- Gumamit ako ng preset theme para safe

-- TABS
local Main = Window:NewTab("Farming")
local Eggs = Window:NewTab("Eggs & Spin")
local Misc = Window:NewTab("Settings")

-- FARMING SECTION
local FarmSection = Main:NewSection("Auto Farm & Rebirth")

FarmSection:NewToggle("Fast Farm (Reps)", "Auto Clicker/Reps", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local Remote = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote")
            if Remote then
                Remote:FireServer("rep")
            end
            task.wait(0.01)
        end
    end)
end)

FarmSection:NewToggle("Fast Rebirth", "Automatic Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") 
            end)
            task.wait(1)
        end
    end)
end)

-- EGGS SECTION
local EggSection = Eggs:NewSection("Auto Hatch & Spin")

local SelectedEgg = "Common"
EggSection:NewDropdown("Select Rarity", "Pili ng Egg", {"Common", "Rare", "Epic", "Legendary", "Mythic"}, function(v)
    SelectedEgg = v
end)

EggSection:NewToggle("Auto Hatch", "Dapat malapit ka sa Egg", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.eggRemote:InvokeServer("openEgg", SelectedEgg)
            end)
            task.wait(1.5)
        end
    end)
end)

EggSection:NewToggle("Auto Spin Wheel", "Spins every 5s", function(state)
    getgenv().AutoSpin = state
    task.spawn(function()
        while getgenv().AutoSpin do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.wheelEvent:FireServer("spinWheel") 
            end)
            task.wait(5)
        end
    end)
end)

-- SETTINGS SECTION
local SettingSection = Misc:NewSection("Anti-AFK & UI")

SettingSection:NewToggle("Anti-AFK", "Prevent Disconnect", function(state)
    getgenv().AntiAFK = state
end)

SettingSection:NewKeybind("Toggle UI", "Press RightControl", Enum.KeyCode.RightControl, function()
    Library:ToggleUI()
end)

-- ANTI-AFK LOGIC (Back-end)
local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

-- FLOATING BUTTON PARA SA MOBILE / TOGGLE
local CoreGui = game:GetService("CoreGui")
if CoreGui:FindFirstChild("K13_Logo") then CoreGui.K13_Logo:Destroy() end

local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "K13_Logo"
local btn = Instance.new("TextButton", ScreenGui)
btn.Size = UDim2.new(0, 50, 0, 50)
btn.Position = UDim2.new(0, 10, 0.5, 0)
btn.Text = "K13"
btn.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
btn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", btn)

btn.MouseButton1Click:Connect(function()
    Library:ToggleUI()
end)
