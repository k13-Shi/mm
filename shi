-- Main Loop
task.spawn(function()
    local machineactive = game.ReplicatedStorage.RemotesEvent.MachineActiveFunction
    local MachineActiveEvent = game.ReplicatedStorage.RemotesEvent.MachineActiveEvent
    local machineuse = game.Players.LocalPlayer:WaitForChild("Machineuse")
    local bechmemp = game.Workspace:WaitForChild("MachinesFolder"):WaitForChild("Bench Press Muscle Emperor")
    
    while true do
        task.wait(0.1)
        if isapin then game.ReplicatedStorage.RemotesEvent.SpinFunction:InvokeServer() end
        if isAuto then game.ReplicatedStorage.RemotesEvent.RebirthEvent:FireServer() end
        if isAutolift then
            if machineuse.Value == nil then
                machineactive:InvokeServer(bechmemp, true)
            else
                MachineActiveEvent:FireServer()
            end
        end
    end
end)
