-- [ 2. FARM TAB (SUPER FAST REPS + INSTANT REBIRTH) ]
local FarmSection = Farm:NewSection("Turbo Farming")

FarmSection:NewToggle("ULTRA FAST REPS", "No Auto-Equip (Hawakan mo gamit mo)", function(state)
    getgenv().FastRep = state
    task.spawn(function()
        while getgenv().FastRep do
            local LP = game.Players.LocalPlayer
            -- Remote call lang, walang Character Equip logic para hindi mag-punch
            pcall(function() 
                LP.muscleEvent:FireServer("rep") 
            end)
            task.wait() -- Mabilis na loop
        end
    end)
end)

FarmSection:NewToggle("⚡ INSTANT REBIRTH", "Auto Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") 
            end)
            task.wait(0.1)
        end
    end)
end)

-- [ 3. ANTI-AFK TIMER ]
local AfkGui = Instance.new("ScreenGui", CoreGui)
local AfkFrame = Instance.new("Frame", AfkGui)
AfkFrame.Size = UDim2.new(0, 110, 0, 45)
AfkFrame.Position = UDim2.new(0, 15, 0.5, 45)
AfkFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
AfkFrame.Visible = false
Instance.new("UICorner", AfkFrame)
Instance.new("UIStroke", AfkFrame).Color = Color3.fromRGB(138, 43, 226)

local AfkText = Instance.new("TextLabel", AfkFrame)
AfkText.Size = UDim2.new(1, 0, 1, 0)
AfkText.TextColor3 = Color3.fromRGB(138, 43, 226)
AfkText.BackgroundTransparency = 1
AfkText.Text = "AFK: 0s"
AfkText.Font = Enum.Font.GothamBold

local sec = 0
task.spawn(function()
    while task.wait(1) do
        if getgenv().AntiAFK then 
            sec = sec + 1 
            AfkText.Text = "AFK: "..sec.."s" 
        else 
            sec = 0 
        end
    end
end)

FarmSection:NewToggle("Anti-AFK (With Timer)", "Stay online", function(state)
    getgenv().AntiAFK = state
    AfkFrame.Visible = state
end)

-- [ 4. AUTO HATCH ]
local PetSection = Pets:NewSection("Crystal Hatching")
PetSection:NewDropdown("Select Crystal", "Pili ka", {"Common Crystal", "Rare Crystal", "Epic Crystal", "Legendary Crystal", "Abyss Crystal"}, function(v)
    getgenv().SelectedCrystal = v
end)

PetSection:NewToggle("Auto Hatch (SINGLE)", "Kailangan may Gems!", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local crys = getgenv().SelectedCrystal or "Common Crystal"
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", crys, "single") 
            end)
            task.wait(0.5) 
        end
    end)
end)

