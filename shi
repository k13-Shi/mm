local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if (self == ReplicatedStorage:FindFirstChild("kickRemote") or self == ReplicatedStorage:FindFirstChild("globalMessage")) and method == "FireServer" then
        return nil 
    end
    return oldNamecall(self, ...)
end)

