local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "K13 MUSCLE MASTERS 🔥",
   LoadingTitle = "K13 Premium Script",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "K13Config"
   }
})

local Main = Window:CreateTab("Auto Farm", 4483362458)
local Eggs = Window:CreateTab("Auto Hatch", 4483362458)
local Misc = Window:CreateTab("Settings", 4483362458)

local LP = game:GetService("Players").LocalPlayer

Main:CreateSection("Training & Rebirth")

Main:CreateToggle({
   Name = "Fast Farm (Auto Click)",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
      getgenv().AutoFarm = Value
      task.spawn(function()
         while getgenv().AutoFarm do
            pcall(function()
                local tool = LP.Character:FindFirstChildOfClass("Tool") or LP.Backpack:FindFirstChildOfClass("Tool")
                if tool then
                    if tool.Parent ~= LP.Character then
                        tool.Parent = LP.Character
                    end
                    tool:Activate()
                end
                
                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("muscleEvent") or 
                               game:GetService("ReplicatedStorage"):FindFirstChild("repEvent") or
                               (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                
                if remote then
                    remote:FireServer("rep")
                end
            end)
            task.wait(0.01)
         end
      end)
   end,
})

Main:CreateToggle({
   Name = "Auto Rebirth",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      getgenv().AutoRebirth = Value
      task.spawn(function()
         while getgenv().AutoRebirth do
            pcall(function()
                local reb = game:GetService("ReplicatedStorage"):FindFirstChild("rebirthEvent") or 
                            (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("rebirthRemote"))
                if reb then
                    reb:InvokeServer("rebirthRequest")
                end
            end)
            task.wait(1)
         end
      end)
   end,
})

Eggs:CreateSection("Egg Hatching")

local SelectedEgg = "Common"
Eggs:CreateDropdown({
   Name = "Select Egg",
   Options = {"Common", "Rare", "Epic", "Legendary", "Mythic"},
   CurrentOption = {"Common"},
   MultipleOptions = false,
   Flag = "EggRarity",
   Callback = function(Option)
      SelectedEgg = Option[1]
   end,
})

Eggs:CreateToggle({
   Name = "Auto Hatch",
   CurrentValue = false,
   Flag = "AutoHatch",
   Callback = function(Value)
      getgenv().AutoHatch = Value
      task.spawn(function()
         while getgenv().AutoHatch do
            pcall(function()
                local egg = game:GetService("ReplicatedStorage"):FindFirstChild("eggEvent") or 
                            (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("eggRemote"))
                if egg then
                    egg:InvokeServer("openEgg", SelectedEgg)
                end
            end)
            task.wait(1)
         end
      end)
   end,
})

Eggs:CreateToggle({
   Name = "Auto Spin Wheel",
   CurrentValue = false,
   Flag = "AutoSpin",
   Callback = function(Value)
      getgenv().AutoSpin = Value
      task.spawn(function()
         while getgenv().AutoSpin do
            pcall(function()
                local spin = game:GetService("ReplicatedStorage"):FindFirstChild("wheelEvent") or 
                             (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("wheelEvent"))
                if spin then
                    spin:FireServer("spinWheel")
                end
            end)
            task.wait(5)
         end
      end)
   end,
})

Misc:CreateSection("Settings")

Misc:CreateToggle({
   Name = "Anti-AFK",
   CurrentValue = true,
   Flag = "AntiAFK",
   Callback = function(Value)
      getgenv().AntiAFK = Value
   end,
})

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)

Rayfield:Notify({
   Title = "K13 FINAL FIX",
   Content = "Equip your tool then turn on Fast Farm!",
   Duration = 5,
   Image = 4483362458,
})
