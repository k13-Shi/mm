local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if active.AFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

task.spawn(function()
    while task.wait(0.2) do
        if active.Farm then
            pcall(function()
                local machine = game.Workspace.MachinesFolder["Bench Press Muscle Emperor"]
                game.ReplicatedStorage.RemotesEvent.MachineActiveFunction:InvokeServer(machine, true)
                task.wait(0.1)
                game.ReplicatedStorage.RemotesEvent.MachineActiveEvent:FireServer()
            end)
        end
        if active.Rebirth then game.ReplicatedStorage.RemotesEvent.RebirthEvent:FireServer() end
        if active.Spin then game.ReplicatedStorage.RemotesEvent.SpinFunction:InvokeServer() end
    end
end)

task.spawn(function()
    local petKeywords = {"Violet Fury", "Ragehorn", "RedHorn", "Leviathos", "Abyss Titan"}
    while task.wait(0.5) do
        if active.Hatch then
            pcall(function() game.ReplicatedStorage.RemotesEvent.OpenPetEvent:FireServer("mythic") end)
        end
        if active.Delete then
            pcall(function()
                for _, obj in pairs(game.Players.LocalPlayer:GetDescendants()) do
                    for _, petName in pairs(petKeywords) do
                        if obj.Name == petName and obj.Name ~= "Space Dragon" then
                            game.ReplicatedStorage.RemotesEvent.SellPetEvent:FireServer(obj)
                        end
                    end
                end
            end)
        end
    end
end)

