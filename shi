local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", "DarkTheme")

local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("Turbo Farming")

FarmSection:NewToggle("Auto Farm (HoneyDezz Speed)", "Ultra Fast God Mode Reps", function(state)
    getgenv().AutoFarm = state
    if state then
        task.spawn(function()
            local RS = game:GetService("RunService")
            local VIM = game:GetService("VirtualInputManager")
            local LP = game.Players.LocalPlayer
            
            while getgenv().AutoFarm do
                RS.Heartbeat:Wait()
                local remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                
                if remote then
                    if remote.ClassName == "RemoteEvent" then
                        remote:FireServer("rep")
                    else
                        remote:InvokeServer("rep")
                    end
                end
                VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
            end
        end)
    end
end)

FarmSection:NewToggle("Auto Rebirth", "Instant Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            end)
            task.wait()
        end
    end)
end)

local Misc = Window:NewTab("Misc")
local MiscSection = Misc:NewSection("Abyss & Eggs")

MiscSection:NewToggle("Auto Hatch Abyss", "Focus on Abyss Titan", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", "Abyss Egg", "triple")
            end)
            task.wait()
        end
    end)
end)

MiscSection:NewToggle("Anti AFK", "No Kick Mode", function(state)
    getgenv().AntiAFK = state
end)

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)

local Settings = Window:NewTab("Settings")
local SettingsSection = Settings:NewSection("UI Management")

SettingsSection:NewKeybind("Toggle UI Key", "Default: RightControl", Enum.KeyCode.RightControl, function()
	Library:ToggleUI()
end)

local ToggleButton = Instance.new("ScreenGui")
local Button = Instance.new("TextButton")
ToggleButton.Name = "K13Toggle"
ToggleButton.Parent = game:GetService("CoreGui")
Button.Name = "OpenClose"
Button.Parent = ToggleButton
Button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Button.Position = UDim2.new(0, 10, 0.5, 0)
Button.Size = UDim2.new(0, 50, 0, 50)
Button.Text = "K13"
Button.TextColor3 = Color3.fromRGB(255, 255, 255)
