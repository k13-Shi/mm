-- Function to create Modern Toggle Buttons
local function NewToggle(name, text)
    local f = Instance.new("Frame")
    f.Name = name.."_Frame"
    f.Parent = Main
    f.Size = UDim2.new(0.95, 0, 0, 40)
    f.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    
    local c = Instance.new("UICorner", f)
    c.CornerRadius = UDim.new(0, 6)

    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(0.7, 0, 1, 0)
    t.Position = UDim2.new(0.05, 0, 0, 0)
    t.BackgroundTransparency = 1
    t.Text = text
    t.TextColor3 = Color3.fromRGB(230, 230, 230)
    t.Font = Enum.Font.GothamMedium
    t.TextSize = 14
    t.TextXAlignment = Enum.TextXAlignment.Left

    local toggleBG = Instance.new("Frame", f)
    toggleBG.Size = UDim2.new(0, 35, 0, 18)
    toggleBG.Position = UDim2.new(0.85, 0, 0.5, 0)
    toggleBG.AnchorPoint = Vector2.new(0.5, 0.5)
    toggleBG.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    Instance.new("UICorner", toggleBG).CornerRadius = UDim.new(1, 0)

    local dot = Instance.new("Frame", toggleBG)
    dot.Size = UDim2.new(0, 14, 0, 14)
    dot.Position = UDim2.new(0.1, 0, 0.5, 0)
    dot.AnchorPoint = Vector2.new(0, 0.5)
    dot.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    return btn, dot, toggleBG
end

-- Create Buttons (Sunod-sunod gaya ng gusto mo)
local btnFarm, dotFarm, bgFarm = NewToggle("Farm", "Auto Strength (Farm)")
local btnRebirth, dotRebirth, bgRebirth = NewToggle("Rebirth", "Auto Rebirth")
local btnFly, dotFly, bgFly = NewToggle("Fly", "Active FLY Hack")
local btnSpin, dotSpin, bgSpin = NewToggle("Spin", "Auto Spin (Misc)")
local btnAFK, dotAFK, bgAFK = NewToggle("AFK", "Anti-AFK System (Misc)")

-- State Variables
local states = { Farm = false, Rebirth = false, Spin = false, AFK = false, Fly = false }

-- Toggle Animation & Logic
local function handleToggle(varName, dot, bg)
    states[varName] = not states[varName]
    if states[varName] then
        dot:TweenPosition(UDim2.new(0.55, 0, 0.5, 0), "Out", "Quart", 0.2)
        bg.BackgroundColor3 = Color3.fromRGB(150, 0, 255)
    else
        dot:TweenPosition(UDim2.new(0.1, 0, 0.5, 0), "Out", "Quart", 0.2)
        bg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end

-- Button Events
btnFarm.Activated:Connect(function() handleToggle("Farm", dotFarm, bgFarm) end)
btnRebirth.Activated:Connect(function() handleToggle("Rebirth", dotRebirth, bgRebirth) end)
btnFly.Activated:Connect(function() 
    handleToggle("Fly", dotFly, bgFly)
    if states.Fly then loadstring(game:HttpGet("https://pastebin.com/raw/92uVadU5"))() end
end)
btnSpin.Activated:Connect(function() handleToggle("Spin", dotSpin, bgSpin) end)
btnAFK.Activated:Connect(function() 
    handleToggle("AFK", dotAFK, bgAFK)
    if states.AFK then loadstring(game:HttpGet("https://pastebin.com/raw/r37Ct26d", true))() end
end)

