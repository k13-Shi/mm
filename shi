local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "K13 MUSCLE MASTERS 🔥",
   LoadingTitle = "K13 Premium Script",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "K13Config"
   }
})

local Main = Window:CreateTab("Auto Farm", 4483362458) -- Tab Icon
local Eggs = Window:CreateTab("Auto Hatch", 4483362458)
local Misc = Window:CreateTab("Settings", 4483362458)

-- [ AUTO FARM ]
Main:CreateSection("Training & Rebirth")

Main:CreateToggle({
   Name = "Fast Farm (Reps)",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
      getgenv().AutoFarm = Value
      task.spawn(function()
         while getgenv().AutoFarm do
            local Remote = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote")
            if Remote then
               Remote:FireServer("rep")
            end
            task.wait(0.01)
         end
      end)
   end,
})

Main:CreateToggle({
   Name = "Auto Rebirth (Fast)",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      getgenv().AutoRebirth = Value
      task.spawn(function()
         while getgenv().AutoRebirth do
            pcall(function() 
               game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") 
            end)
            task.wait(1)
         end
      end)
   end,
})

-- [ AUTO HATCH ]
Eggs:CreateSection("Egg Hatching")

local SelectedEgg = "Common"
Eggs:CreateDropdown({
   Name = "Select Egg Rarity",
   Options = {"Common", "Rare", "Epic", "Legendary", "Mythic"},
   CurrentOption = {"Common"},
   MultipleOptions = false,
   Flag = "EggRarity",
   Callback = function(Option)
      SelectedEgg = Option[1]
   end,
})

Eggs:CreateToggle({
   Name = "Auto Hatch Eggs",
   CurrentValue = false,
   Flag = "AutoHatch",
   Callback = function(Value)
      getgenv().AutoHatch = Value
      task.spawn(function()
         while getgenv().AutoHatch do
            pcall(function()
               game:GetService("ReplicatedStorage").rEvents.eggRemote:InvokeServer("openEgg", SelectedEgg)
            end)
            task.wait(1.5)
         end
      end)
   end,
})

Eggs:CreateToggle({
   Name = "Auto Spin Wheel",
   CurrentValue = false,
   Flag = "AutoSpin",
   Callback = function(Value)
      getgenv().AutoSpin = Value
      task.spawn(function()
         while getgenv().AutoSpin do
            pcall(function() 
               game:GetService("ReplicatedStorage").rEvents.wheelEvent:FireServer("spinWheel") 
            end)
            task.wait(5)
         end
      end)
   end,
})

-- [ SETTINGS ]
Misc:CreateSection("Extra Features")

Misc:CreateToggle({
   Name = "Anti-AFK",
   CurrentValue = true,
   Flag = "AntiAFK",
   Callback = function(Value)
      getgenv().AntiAFK = Value
   end,
})

-- Anti-AFK Background Logic
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)

Rayfield:Notify({
   Title = "K13 LOADED!",
   Content = "Ready to farm, Muscle Master!",
   Duration = 5,
   Image = 4483362458,
})
