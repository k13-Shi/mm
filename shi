local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "K13 MUSCLE MASTERS 🔥",
    SubTitle = "by shi | Premium Edition",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main Farm", Icon = "dumbbell" }),
    Settings = Window:AddTab({ Title = "Settings", Icon = "settings" })
}

Tabs.Main:AddParagraph({
    Title = "Strength Farming",
    Content = "Automatic strength training and fast reps."
})

local StrengthToggle = Tabs.Main:AddToggle("AutoStrength", {Title = "🔥 Auto Strength + Fast Rep", Default = false })
StrengthToggle:OnChanged(function()
    getgenv().StrengthFarm = StrengthToggle.Value
    
    task.spawn(function()
        while getgenv().StrengthFarm do
            local p = game.Players.LocalPlayer
            local weight = p.Backpack:FindFirstChild("Weight") or p.Character:FindFirstChild("Weight")
            if weight then
                if weight.Parent == p.Backpack then
                    p.Character.Humanoid:EquipTool(weight)
                end
                if weight:FindFirstChild("repTime") then
                    weight.repTime.Value = 0
                end
            end
            task.wait(0.5)
        end
    end)

    task.spawn(function()
        while getgenv().StrengthFarm do
            game:GetService("Players").LocalPlayer.muscleEvent:FireServer("rep")
            task.wait() 
        end
    end)
end)

local RebirthToggle = Tabs.Main:AddToggle("AutoRebirth", {Title = "⚡ Auto Fast Rebirth", Default = false })
RebirthToggle:OnChanged(function()
    getgenv().FastRebirth = RebirthToggle.Value
    task.spawn(function()
        while getgenv().FastRebirth do
            game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            task.wait(0.1)
        end
    end)
end)

local SpinToggle = Tabs.Main:AddToggle("AutoSpin", {Title = "🎡 Auto Spin Wheels", Default = false })
SpinToggle:OnChanged(function()
    getgenv().AutoSpin = SpinToggle.Value
    task.spawn(function()
        while getgenv().AutoSpin do
            game:GetService("ReplicatedStorage").rEvents.wheelRemote:InvokeServer("spinWheel")
            task.wait(2)
        end
    end)
end)

Tabs.Settings:AddParagraph({
    Title = "Player Utilities",
    Content = "Extra features to keep your account safe."
})

local AntiAFKToggle = Tabs.Settings:AddToggle("AntiAFK", {Title = "🚫 Anti-AFK (Stay Online)", Default = false })
AntiAFKToggle:OnChanged(function()
    getgenv().AntiAFK = AntiAFKToggle.Value
    
    if getgenv().AntiAFK then
        Fluent:Notify({ Title = "Anti-AFK", Content = "Anti-AFK is now ACTIVE.", Duration = 3 })
    else
        Fluent:Notify({ Title = "Anti-AFK", Content = "Anti-AFK is now DISABLED.", Duration = 3 })
    end
end)

local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

Tabs.Settings:AddToggle("TinySize", {
    Title = "Always Tiny Size",
    Default = false,
    Callback = function(state)
        getgenv().TinySize = state
        task.spawn(function()
            while getgenv().TinySize do
                game:GetService("ReplicatedStorage").rEvents.changeSpeedSizeRemote:InvokeServer("changeSize", 0)
                task.wait(1)
            end
        end)
    end
})

Tabs.Settings:AddButton({
    Title = "Destroy UI",
    Description = "Completely remove the script interface",
    Callback = function()
        Window:Destroy()
    end
})

Fluent:Notify({
    Title = "K13 Loaded",
    Content = "Ready to build some muscles!",
    Duration = 5
})

Window:SelectTab(1)
