local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("8-Pack Turbo Farm")

FarmSection:NewToggle("8-PACK SPEED (STABLE)", "Fast Reps (Stay Mode)", function(state)
    getgenv().AutoFarm = state
    if state then
        task.spawn(function()
            while getgenv().AutoFarm do
                local Remote = game.Players.LocalPlayer:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                if Remote then
                    for i = 1, 15 do
                        pcall(function() Remote:FireServer("rep") end)
                    end
                end
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, true, game, 0)
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, false, game, 0)
                task.wait(0.01)
            end
        end)
    end
end)

FarmSection:NewToggle("Instant Rebirth", "Auto Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") end)
            task.wait(0.1)
        end
    end)
end)

local Combat = Window:NewTab("Combat")
local CombatSection = Combat:NewSection("Player Kill & Toxic System")

local PlayerList = {}
local function getPlayers()
    PlayerList = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer then
            table.insert(PlayerList, v.Name)
        end
    end
    return PlayerList
end

local TargetDropdown = CombatSection:NewDropdown("Select Target Player", "Piliin ang biktima", getPlayers(), function(v)
    getgenv().SelectedPlayer = v
end)

CombatSection:NewButton("🔄 Refresh Player List", "Update list", function()
    TargetDropdown:Refresh(getPlayers())
end)

local ToxicMessages = {
    "L",
    "K13 OWNED YOU!",
    "EZ STATS",
    "GO CRY TO YOUR MOM",
    "PRACTICE MORE KID",
    "K13 ON TOP",
    "STOP RUNNING EZ",
    "I'M JUST BETTER",
    "Hacker? No, just K13.",
    "Imagine being this weak lol"
}

CombatSection:NewToggle("☣️ Auto Toxic Message", "Magcha-chat ng toxic pag pumapatay", function(state)
    getgenv().AutoToxic = state
end)

local function sayToxic()
    if getgenv().AutoToxic then
        local msg = ToxicMessages[math.random(1, #ToxicMessages)]
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(msg, "All")
    end
end

CombatSection:NewToggle("⚔️ Auto Kill Selected", "TP and Kill target", function(state)
    getgenv().AutoKill = state
    task.spawn(function()
        while getgenv().AutoKill do
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                game:GetService("Players").LocalPlayer.muscleEvent:FireServer("rep")
                if target.Character.Humanoid.Health <= 0 then
                    sayToxic()
                    task.wait(1)
                end
            end
            task.wait()
        end
    end)
end)

CombatSection:NewToggle("👁️ View Player", "Stalk target", function(state)
    getgenv().ViewPlayer = state
    task.spawn(function()
        while getgenv().ViewPlayer do
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character then
                workspace.CurrentCamera.CameraSubject = target.Character.Humanoid
            end
            task.wait(0.1)
        end
        workspace.CurrentCamera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
    end)
end)

CombatSection:NewToggle("💀 KILL ALL", "Papatayin lahat sa server", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = v.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                    game:GetService("Players").LocalPlayer.muscleEvent:FireServer("rep")
                    if v.Character.Humanoid.Health <= 0 then
                        sayToxic()
                    end
                    task.wait(0.3)
                end
            end
            task.wait()
        end
    end)
end)

