-- [ 2. FARM SECTION ]
local FarmSection = Farm:NewSection("Turbo Farming")
FarmSection:NewToggle("8-PACK SPEED", "Fast Reps + Auto Equip", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool and LP.Character then LP.Character.Humanoid:EquipTool(tool) end
            local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
            if Remote then for i = 1, 25 do pcall(function() Remote:FireServer("rep") end) end end
            task.wait(0.001)
        end
    end)
end)

FarmSection:NewToggle("Instant Rebirth", "No delay", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") end)
            task.wait(0.1)
        end
    end)
end)

-- [ 3. COMBAT SECTION (FAR REACH) ]
local CombatSection = Combat:NewSection("Player Kill & View System")

local function forceEquipPunch()
    local LP = game.Players.LocalPlayer
    local punch = LP.Backpack:FindFirstChild("Punch") or LP.Character:FindFirstChild("Punch")
    if punch and LP.Character and punch.Parent ~= LP.Character then
        LP.Character.Humanoid:EquipTool(punch)
    end
end

local function getPlayers()
    local p = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer then table.insert(p, v.Name) end
    end
    return p
end

local TargetDropdown = CombatSection:NewDropdown("Select Player", "Target names", getPlayers(), function(v)
    getgenv().SelectedPlayer = v
end)

CombatSection:NewButton("🔄 Refresh Player List", "Update Names", function()
    TargetDropdown:Refresh(getPlayers())
end)

CombatSection:NewToggle("⚔️ Auto Kill Selected", "Sapak kahit malayo", function(state)
    getgenv().AutoKill = state
    task.spawn(function()
        while getgenv().AutoKill do
            forceEquipPunch()
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character then
                pcall(function()
                    game.Players.LocalPlayer.muscleEvent:FireServer("punchClick", target.Character)
                    game.Players.LocalPlayer.muscleEvent:FireServer("rep", target.Character)
                end)
            end
            task.wait(0.01)
        end
    end)
end)

CombatSection:NewToggle("💀 KILL ALL (REMOTE REACH)", "Sapak lahat sa server", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            forceEquipPunch()
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character then
                    pcall(function()
                        game.Players.LocalPlayer.muscleEvent:FireServer("punchClick", v.Character)
                        game.Players.LocalPlayer.muscleEvent:FireServer("rep", v.Character)
                    end)
                end
            end
            task.wait(0.1)
        end
    end)
end)

