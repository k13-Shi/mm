local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "K13 MUSCLE MASTERS 🔥",
   LoadingTitle = "K13 V15 - STABLE FIX",
   LoadingSubtitle = "No Mouse Click | 0.1 Speed",
   ConfigurationSaving = { Enabled = false }
})

local Main = Window:CreateTab("Auto Farm", 4483362458)
local Eggs = Window:CreateTab("Auto Hatch", 4483362458)
local Misc = Window:CreateTab("Settings", 4483362458)

local LP = game:GetService("Players").LocalPlayer

local function getRemote(name)
    for _, v in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
        if v.Name:lower():find(name:lower()) and (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) then
            return v
        end
    end
end

Main:CreateSection("Training & Rebirth")

Main:CreateToggle({
   Name = "Fast Farm",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
      getgenv().AutoFarm = Value
      task.spawn(function()
         local repRem = getRemote("rep")
         while getgenv().AutoFarm do
            pcall(function()
               local tool = LP.Character:FindFirstChildOfClass("Tool")
               if tool then
                  tool:Activate()
               end
               if repRem then
                  repRem:FireServer("rep")
               end
            end)
            task.wait(1)
         end
      end)
   end,
})

Main:CreateToggle({
   Name = "Auto Rebirth (0.1 Speed)",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      getgenv().AutoRebirth = Value
      task.spawn(function()
         local rebRem = getRemote("rebirth")
         while getgenv().AutoRebirth do
            pcall(function()
               if rebRem:IsA("RemoteFunction") then
                  rebRem:InvokeServer("rebirthRequest")
               else
                  rebRem:FireServer("rebirthRequest")
               end
            end)
            task.wait(1)
         end
      end)
   end,
})

Eggs:CreateSection("Auto Hatch & Spin")

local SelectedEgg = "Common"
Eggs:CreateDropdown({
   Name = "Select Egg",
   Options = {"Common", "Rare", "Epic", "Legendary", "Mythic"},
   CurrentOption = {"Common"},
   Flag = "EggRarity",
   Callback = function(Option) SelectedEgg = Option[1] end,
})

Eggs:CreateToggle({
   Name = "Auto Hatch",
   CurrentValue = false,
   Flag = "AutoHatch",
   Callback = function(Value)
      getgenv().AutoHatch = Value
      task.spawn(function()
         local eggRem = getRemote("egg") or getRemote("open")
         while getgenv().AutoHatch do
            pcall(function()
               if eggRem:IsA("RemoteFunction") then
                  eggRem:InvokeServer("openEgg", SelectedEgg)
               else
                  eggRem:FireServer("openEgg", SelectedEgg)
               end
            end)
            task.wait(5)
         end
      end)
   end,
})

Eggs:CreateToggle({
   Name = "Auto Spin",
   CurrentValue = false,
   Flag = "AutoSpin",
   Callback = function(Value)
      getgenv().AutoSpin = Value
      task.spawn(function()
         local spinRem = getRemote("wheel") or getRemote("spin")
         while getgenv().AutoSpin do
            pcall(function()
               spinRem:FireServer("spinWheel")
            end)
            task.wait(5)
         end
      end)
   end,
})

Misc:CreateSection("Safety")

Misc:CreateToggle({
   Name = "Anti-AFK",
   CurrentValue = true,
   Flag = "AntiAFK",
   Callback = function(Value) getgenv().AntiAFK = Value end,
})

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)
