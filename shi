local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "K13 MUSCLE MASTERS 🔥",
   LoadingTitle = "K13 V12 - THE FINAL FIX",
   LoadingSubtitle = "Direct Injection Mode",
   ConfigurationSaving = { Enabled = false }
})

local Main = Window:CreateTab("Auto Farm", 4483362458)
local Eggs = Window:CreateTab("Auto Hatch", 4483362458)
local Misc = Window:CreateTab("Settings", 4483362458)

local RS = game:GetService("ReplicatedStorage")

local function getRemote(name)
    for _, v in pairs(RS:GetDescendants()) do
        if v.Name:lower():find(name:lower()) and (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) then
            return v
        end
    end
end

Main:CreateSection("Training & Rebirth")

Main:CreateToggle({
   Name = "Fast Farm",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
      getgenv().AutoFarm = Value
      task.spawn(function()
         local rem = getRemote("rep")
         while getgenv().AutoFarm do
            if rem then rem:FireServer("rep") end
            task.wait(0.1)
         end
      end)
   end,
})

Main:CreateToggle({
   Name = "Auto Rebirth",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      getgenv().AutoRebirth = Value
      task.spawn(function()
         local rem = getRemote("rebirth")
         while getgenv().AutoRebirth do
            if rem then 
                if rem:IsA("RemoteFunction") then rem:InvokeServer("rebirthRequest") else rem:FireServer("rebirthRequest") end
            end
            task.wait(1)
         end
      end)
   end,
})

Eggs:CreateSection("Auto Hatch & Spin")

local SelectedEgg = "Common"
Eggs:CreateDropdown({
   Name = "Select Egg",
   Options = {"Common", "Rare", "Epic", "Legendary", "Mythic"},
   CurrentOption = {"Common"},
   Flag = "EggRarity",
   Callback = function(Option) SelectedEgg = Option[1] end,
})

Eggs:CreateToggle({
   Name = "Auto Hatch",
   CurrentValue = false,
   Flag = "AutoHatch",
   Callback = function(Value)
      getgenv().AutoHatch = Value
      task.spawn(function()
         local rem = getRemote("egg") or getRemote("open")
         while getgenv().AutoHatch do
            if rem then
                if rem:IsA("RemoteFunction") then rem:InvokeServer("openEgg", SelectedEgg) else rem:FireServer("openEgg", SelectedEgg) end
            end
            task.wait(0.5)
         end
      end)
   end,
})

Eggs:CreateToggle({
   Name = "Auto Spin Wheel",
   CurrentValue = false,
   Flag = "AutoSpin",
   Callback = function(Value)
      getgenv().AutoSpin = Value
      task.spawn(function()
         local rem = getRemote("wheel") or getRemote("spin")
         while getgenv().AutoSpin do
            if rem then rem:FireServer("spinWheel") end
            task.wait(5)
         end
      end)
   end,
})

Misc:CreateSection("Safety")

Misc:CreateToggle({
   Name = "Anti-AFK",
   CurrentValue = true,
   Flag = "AntiAFK",
   Callback = function(Value) getgenv().AntiAFK = Value end,
})

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)
