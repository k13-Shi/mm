local Farm = Window:NewTab("Farm")
local Pets = Window:NewTab("Auto Hatch/Spin")
local Settings = Window:NewTab("Settings")

-- [ 1. LOGO & BUTTON FIX (NO 3 LINES) ]
local CoreGui = game:GetService("CoreGui")
task.spawn(function()
    while task.wait(0.1) do
        for _, v in pairs(CoreGui:GetDescendants()) do
            if v:IsA("ImageButton") and (v.Name == "ToggleButton" or v.Name == "KavoToggleButton") then
                v:Destroy()
            end
        end
    end
end)

if CoreGui:FindFirstChild("K13_Violet_Logo") then CoreGui:FindFirstChild("K13_Violet_Logo"):Destroy() end
local MainGui = Instance.new("ScreenGui", CoreGui)
MainGui.Name = "K13_Violet_Logo"
local K13Button = Instance.new("ImageButton", MainGui)
K13Button.Size = UDim2.new(0, 60, 0, 60)
K13Button.Position = UDim2.new(0, 15, 0.5, -30)
K13Button.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
K13Button.Image = "rbxassetid://6031097225" 
K13Button.Draggable = true
Instance.new("UICorner", K13Button).CornerRadius = UDim.new(1, 0)
K13Button.MouseButton1Click:Connect(function() Library:ToggleUI() end)

-- [ 2. HOME TAB ]
Home:NewSection("🟣 K13 PREMIUM VIOLET 🟣")
Home:NewSection("STATUS: COMBAT REMOVED / AFK FIXED")

-- [ 3. FARM TAB (WITH INSTANT REBIRTH) ]
local FarmSection = Farm:NewSection("Turbo Farming")
FarmSection:NewToggle("8-PACK SPEED", "Fast Reps", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool then LP.Character.Humanoid:EquipTool(tool) end
            pcall(function() LP.muscleEvent:FireServer("rep") end)
            task.wait()
        end
    end)
end)

FarmSection:NewToggle("⚡ INSTANT REBIRTH", "Awtomatikong Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") 
            end)
            task.wait(0.1)
        end
    end)
end)

-- [ 4. ANTI-AFK TIMER BOX ]
local AfkGui = Instance.new("ScreenGui", CoreGui)
local AfkFrame = Instance.new("Frame", AfkGui)
AfkFrame.Size = UDim2.new(0, 110, 0, 45)
AfkFrame.Position = UDim2.new(0, 15, 0.5, 45)
AfkFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
AfkFrame.Visible = false
Instance.new("UICorner", AfkFrame)
Instance.new("UIStroke", AfkFrame).Color = Color3.fromRGB(138, 43, 226)

local AfkText = Instance.new("TextLabel", AfkFrame)
AfkText.Size = UDim2.new(1, 0, 1, 0)
AfkText.TextColor3 = Color3.fromRGB(138, 43, 226)
AfkText.BackgroundTransparency = 1
AfkText.Text = "AFK: 0s"
AfkText.Font = Enum.Font.GothamBold

local sec = 0
task.spawn(function()
    while task.wait(1) do
        if getgenv().AntiAFK then 
            sec = sec + 1 
            AfkText.Text = "AFK: "..sec.."s" 
        else 
            sec = 0 
        end
    end
end)

FarmSection:NewToggle("Anti-AFK (With Timer)", "Stay online 24/7", function(state)
    getgenv().AntiAFK = state
    AfkFrame.Visible = state
end)

-- [ 5. AUTO HATCH/SPIN ]
local PetSection = Pets:NewSection("Crystal Hatching")
PetSection:NewDropdown("Select Crystal", "Pili ka Crystal", {"Common Crystal", "Rare Crystal", "Epic Crystal", "Legendary Crystal", "Abyss Crystal"}, function(v)
    getgenv().SelectedCrystal = v
end)

PetSection:NewToggle("Auto Hatch (SINGLE)", "Dapat may Gems ka!", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local crys = getgenv().SelectedCrystal or "Common Crystal"
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", crys, "single") 
            end)
            task.wait(0.5) 
        end
    end)
end)

PetSection:NewToggle("Auto Spin Wheel", "Awtomatikong Spin", function(state)
    getgenv().AutoSpin = state
    task.spawn(function()
        while getgenv().AutoSpin do
            pcall(function() 
                game:GetService("ReplicatedStorage").rEvents.wheelEvent:FireServer("spinWheel") 
            end)
            task.wait(5)
        end
    end)
end)

