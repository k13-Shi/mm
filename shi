local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", "DarkTheme")

local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("Main Farming")

FarmSection:NewToggle("Auto Farm", "Starts clicking and lifting reps", function(state)
    getgenv().AutoFarm = state
    if state then
        task.spawn(function()
            while getgenv().AutoFarm do
                local remote = game:GetService("Players").LocalPlayer:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                if remote then
                    if remote.ClassName == "RemoteEvent" then
                        remote:FireServer("rep")
                    elseif remote.ClassName == "RemoteFunction" then
                        remote:InvokeServer("rep")
                    end
                end
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, true, game, 0)
                task.wait()
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, false, game, 0)
                task.wait(0.001)
            end
        end)
    end
end)

FarmSection:NewToggle("Auto Rebirth", "Automatic rebirth when possible", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            end)
            task.wait(0.5)
        end
    end)
end)

local Misc = Window:NewTab("Misc")
local MiscSection = Misc:NewSection("Eggs & Utilities")

MiscSection:NewDropdown("Select Eggs", "Choose which egg to hatch", {"Abyss Egg", "Common Egg", "Rare Egg"}, function(currentOption)
    getgenv().SelectedEgg = currentOption
end)

MiscSection:NewToggle("Auto Eggs", "Auto hatch selected egg", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local egg = getgenv().SelectedEgg or "Abyss Egg"
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", egg, "triple")
            end)
            task.wait(0.3)
        end
    end)
end)

MiscSection:NewToggle("Auto Spin", "Auto spin the wheel", function(state)
    getgenv().AutoSpin = state
    task.spawn(function()
        while getgenv().AutoSpin do
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.wheelRemote:InvokeServer("spinWheel")
            end)
            task.wait(2)
        end
    end)
end)

MiscSection:NewToggle("Anti AFK", "Prevents getting kicked", function(state)
    getgenv().AntiAFK = state
end)

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)

local Settings = Window:NewTab("Settings")
local SettingsSection = Settings.NewSection("UI Controls")

SettingsSection:NewKeybind("Toggle UI", "Key to hide/show menu", Enum.KeyCode.RightControl, function()
	Library:ToggleUI()
end)
