local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("Turbo Farming")

FarmSection:NewToggle("8-PACK SPEED (STABLE)", "Ultra Fast Reps + Auto Equip", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool and LP.Character then LP.Character.Humanoid:EquipTool(tool) end
            local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
            if Remote then for i = 1, 25 do pcall(function() Remote:FireServer("rep") end) end end
            task.wait(0.001)
        end
    end)
end)

FarmSection:NewToggle("Instant Auto Rebirth", "No delay", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") end)
            task.wait(0.1)
        end
    end)
end)

-- [ ANTI-AFK WITH VIOLET NOTIFICATION ]
local function createNotif()
    local sg = Instance.new("ScreenGui", game.CoreGui)
    sg.Name = "K13_AFK_Notif"
    
    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0, 200, 0, 100)
    frame.Position = UDim2.new(0.5, -100, 0.1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    frame.BorderSizePixel = 0
    frame.Visible = false
    
    local corner = Instance.new("UICorner", frame)
    local border = Instance.new("UIStroke", frame)
    border.Color = Color3.fromRGB(138, 43, 226)
    border.Thickness = 2
    
    local img = Instance.new("ImageLabel", frame)
    img.Size = UDim2.new(0, 40, 0, 40)
    img.Position = UDim2.new(0.5, -20, 0.1, 0)
    img.Image = "rbxassetid://6031097225"
    img.BackgroundTransparency = 1
    
    local txt = Instance.new("TextLabel", frame)
    txt.Size = UDim2.new(1, 0, 0, 30)
    txt.Position = UDim2.new(0, 0, 0.6, 0)
    txt.Text = "ANTI-AFK ACTIVE"
    txt.TextColor3 = Color3.fromRGB(138, 43, 226)
    txt.BackgroundTransparency = 1
    txt.Font = Enum.Font.GothamBold
    txt.TextSize = 14
    
    return frame
end

local afkFrame = createNotif()

FarmSection:NewToggle("Anti-AFK (No Kick)", "Stay online 24/7", function(state)
    getgenv().AntiAFK = state
    afkFrame.Visible = state
end)

FarmSection:NewButton("Toggle AFK Notif View", "Open/Close AFK Message", function()
    afkFrame.Visible = not afkFrame.Visible
end)

-- [ TAB 3: COMBAT ]
local Combat = Window:NewTab("Combat")
local CombatSection = Combat:NewSection("Kill & View (No Teleport)")

local function forceEquipPunch()
    local LP = game.Players.LocalPlayer
    local punch = LP.Backpack:FindFirstChild("Punch") or LP.Character:FindFirstChild("Punch")
    if punch and LP.Character and punch.Parent ~= LP.Character then
        LP.Character.Humanoid:EquipTool(punch)
    end
end

CombatSection:NewToggle("💀 KILL ALL (NO TELEPORT)", "Instant kill everyone", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            forceEquipPunch()
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character then
                    pcall(function()
                        game.Players.LocalPlayer.muscleEvent:FireServer("punchClick", v.Character)
                        game.Players.LocalPlayer.muscleEvent:FireServer("rep", v.Character)
                    end)
                end
            end
            task.wait(0.1)
        end
    end)
end)

CombatSection:NewToggle("☣️ Auto Toxic", "Chat L on kill", function(state)
    getgenv().AutoToxic = state
end)

