-- Function para sa "NoLimit" Style Button/Toggle
local function CreateToggle(parent, text, defaultVar)
    local frame = Instance.new("Frame")
    local btn = Instance.new("TextButton")
    local check = Instance.new("Frame")

    frame.Size = UDim2.new(1, 0, 0, 45)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.Parent = parent
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = "  " .. text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 14
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = frame

    check.Size = UDim2.new(0, 20, 0, 20)
    check.Position = UDim2.new(0.9, -10, 0.5, -10)
    check.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    check.Parent = frame
    Instance.new("UICorner", check).CornerRadius = UDim.new(0, 4)

    local inner = Instance.new("Frame", check)
    inner.Size = UDim2.new(0, 0, 0, 0)
    inner.Position = UDim2.new(0.5, 0, 0.5, 0)
    inner.AnchorPoint = Vector2.new(0.5, 0.5)
    inner.BackgroundColor3 = Color3.fromRGB(255, 170, 0) -- Gold/Orange gaya ng NoLimit
    Instance.new("UICorner", inner).CornerRadius = UDim.new(0, 3)

    return btn, inner
end

-- Create the Toggles (Sunod-sunod gaya ng request mo)
local btnFarm, dotFarm = CreateToggle(Container, "Auto Strength (Farm)")
local btnRebirth, dotRebirth = CreateToggle(Container, "Auto Rebirth")
local btnSpin, dotSpin = CreateToggle(Container, "Auto Spin (Misc)")
local btnAFK, dotAFK = CreateToggle(Container, "Anti-AFK System (Misc)")

-- Logic Variables
local flags = { Farm = false, Rebirth = false, Spin = false, AFK = false }

local function toggleUI(dot, bool)
    dot:TweenSize(bool and UDim2.new(0.7, 0, 0.7, 0) or UDim2.new(0, 0, 0, 0), "Out", "Back", 0.15)
end

-- Button Connections
btnFarm.MouseButton1Click:Connect(function()
    flags.Farm = not flags.Farm
    toggleUI(dotFarm, flags.Farm)
end)

btnRebirth.MouseButton1Click:Connect(function()
    flags.Rebirth = not flags.Rebirth
    toggleUI(dotRebirth, flags.Rebirth)
end)

btnSpin.MouseButton1Click:Connect(function()
    flags.Spin = not flags.Spin
    toggleUI(dotSpin, flags.Spin)
end)

btnAFK.MouseButton1Click:Connect(function()
    flags.AFK = not flags.AFK
    toggleUI(dotAFK, flags.AFK)
    if flags.AFK then loadstring(game:HttpGet("https://pastebin.com/raw/r37Ct26d", true))() end
end)

-- Main Loop para sa Farm at Rebirth
task.spawn(function()
    while true do
        task.wait(0.1)
        if flags.Spin then game.ReplicatedStorage.RemotesEvent.SpinFunction:InvokeServer() end
        if flags.Rebirth then game.ReplicatedStorage.RemotesEvent.RebirthEvent:FireServer() end
        if flags.Farm then
            local machineuse = game.Players.LocalPlayer:WaitForChild("Machineuse")
            if machineuse.Value == nil then
                game.ReplicatedStorage.RemotesEvent.MachineActiveFunction:InvokeServer(game.Workspace.MachinesFolder["Bench Press Muscle Emperor"], true)
            else
                game.ReplicatedStorage.RemotesEvent.MachineActiveEvent:FireServer()
            end
        end
    end
end)

