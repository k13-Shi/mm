local function NewTabBtn(n, p, t)
    local b = Instance.new("TextButton", K13_Sidebar)
    b.Size = UDim2.new(0.9, 0, 0, 30)
    b.Position = UDim2.new(0.05, 0, 0, p)
    b.BackgroundColor3 = Color3.fromRGB(45, 20, 80)
    b.Text = n
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.Font = Enum.Font.GothamMedium
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        for _, f in pairs(K13_Tabs) do f.Visible = false end
        t.Visible = true
    end)
end

for name, frame in pairs(K13_Tabs) do
    frame.Parent = K13_Content
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Visible = (name == "Main")
    local l = Instance.new("UIListLayout", frame)
    l.Padding = UDim.new(0, 8)
    l.SortOrder = Enum.SortOrder.LayoutOrder -- Para sunod-sunod
end

local function NewToggle(p, t, c, lo)
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1, 0, 0, 35)
    f.BackgroundColor3 = Color3.fromRGB(30, 15, 55)
    f.LayoutOrder = lo or 0
    Instance.new("UICorner", f)
    Instance.new("UIStroke", f).Color = Color3.fromRGB(180, 50, 255)
    local b = Instance.new("TextButton", f)
    b.Size = UDim2.new(1, 0, 1, 0)
    b.BackgroundTransparency = 1
    b.Text = "  " .. t
    b.TextColor3 = Color3.fromRGB(230, 200, 255)
    b.TextXAlignment = Enum.TextXAlignment.Left
    local on = false
    b.MouseButton1Click:Connect(function()
        on = not on
        f.BackgroundColor3 = on and Color3.fromRGB(70, 30, 120) or Color3.fromRGB(30, 15, 55)
        c(on)
    end)
end

local function NewInput(p, t, c, lo)
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1, 0, 0, 35)
    f.BackgroundColor3 = Color3.fromRGB(30, 15, 55)
    f.LayoutOrder = lo or 0
    Instance.new("UICorner", f)
    Instance.new("UIStroke", f).Color = Color3.fromRGB(180, 50, 255)
    local i = Instance.new("TextBox", f)
    i.Size = UDim2.new(1, 0, 1, 0)
    i.BackgroundTransparency = 1
    i.Text = t
    i.TextColor3 = Color3.fromRGB(255, 255, 255)
    i.PlaceholderText = "Enter Value..."
    i.FocusLost:Connect(function() c(i.Text) end)
end

