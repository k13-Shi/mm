local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", "Violet")

local Main = Window:NewTab("K13 Home")
local MainSection = Main:NewSection("🟣 K13 PREMIUM EXCLUSIVE 🟣")

MainSection:NewLabel("K13 VIOLET EDITION LOADED")

MainSection:NewLabel("✨ GOD-SPEED ACTIVE ✨")

local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("8-Pack Turbo Farm")

FarmSection:NewToggle("8-PACK SPEED (NO DELAY)", "Pinakamabilis na Reps (Stay Mode)", function(state)
    getgenv().AutoFarm = state
    if state then
        for i = 1, 15 do
            task.spawn(function()
                local LP = game.Players.LocalPlayer
                local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                while getgenv().AutoFarm do
                    if Remote then
                        if Remote.ClassName == "RemoteEvent" then
                            Remote:FireServer("rep")
                        else
                            Remote:InvokeServer("rep")
                        end
                    end
                    game:GetService("RunService").Heartbeat:Wait()
                end
            end)
        end
        task.spawn(function()
            local VIM = game:GetService("VirtualInputManager")
            while getgenv().AutoFarm do
                VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                task.wait()
            end
        end)
    end
end)

FarmSection:NewToggle("Instant Rebirth", "Automatic Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            end)
            task.wait()
        end
    end)
end)

local Pets = Window:NewTab("Auto Hatch")
local PetSection = Pets:NewSection("Egg Hatching")

PetSection:NewDropdown("Select Egg", "Pili ka muna bago i-on", {"Abyss Egg", "Common Egg", "Rare Egg", "Legendary Egg"}, function(v)
    getgenv().SelectedEgg = v
end)

PetSection:NewToggle("Auto Hatch (Triple)", "Spam hatch pets", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local egg = getgenv().SelectedEgg or "Abyss Egg"
            pcall(function()
                game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", egg, "triple")
            end)
            task.wait()
        end
    end)
end)

