local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "K13 MUSCLE MASTERS 🔥",
    SubTitle = "by shi | No-TP Edition",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main Farm", Icon = "dumbbell" }),
    Pets = Window:AddTab({ Title = "Auto Hatch", Icon = "dog" }),
    Settings = Window:AddTab({ Title = "Settings", Icon = "settings" })
}

local function startLifting()
    task.spawn(function()
        while getgenv().AutoLift do
            game:GetService("Players").LocalPlayer.muscleEvent:FireServer("rep")
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, true, game, 0)
            task.wait()
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, false, game, 0)
            task.wait(0.01)
        end
    end)
end

local LiftToggle = Tabs.Main:AddToggle("AutoLift", {Title = "🏋️ Start Auto Lift (No TP)", Default = false })
LiftToggle:OnChanged(function()
    getgenv().AutoLift = LiftToggle.Value
    if getgenv().AutoLift then
        startLifting()
    end
end)

local RebirthToggle = Tabs.Main:AddToggle("AutoRebirth", {Title = "⚡ Auto Fast Rebirth", Default = false })
RebirthToggle:OnChanged(function()
    getgenv().FastRebirth = RebirthToggle.Value
    task.spawn(function()
        while getgenv().FastRebirth do
            game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            task.wait(0.5)
        end
    end)
end)

local AbyssHatch = Tabs.Pets:AddToggle("HatchAbyss", {Title = "🌌 Auto Hatch Abyss Egg", Default = false })
AbyssHatch:OnChanged(function()
    getgenv().AutoHatch = AbyssHatch.Value
    task.spawn(function()
        while getgenv().AutoHatch do
            game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", "Abyss Egg", "triple")
            task.wait(0.3)
        end
    end)
end)

local EquipBest = Tabs.Pets:AddToggle("EquipBest", {Title = "🐾 Auto Equip Best Pets", Default = false })
EquipBest:OnChanged(function()
    getgenv().AutoEquip = EquipBest.Value
    task.spawn(function()
        while getgenv().AutoEquip do
            game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("equipBest")
            task.wait(5)
        end
    end)
end)

local AntiAFKToggle = Tabs.Settings:AddToggle("AntiAFK", {Title = "🚫 Anti-AFK", Default = false })
AntiAFKToggle:OnChanged(function()
    getgenv().AntiAFK = AntiAFKToggle.Value
end)

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)

Tabs.Settings:AddToggle("TinySize", {
    Title = "Auto Tiny Size",
    Default = false,
    Callback = function(state)
        getgenv().TinySize = state
        task.spawn(function()
            while getgenv().TinySize do
                game:GetService("ReplicatedStorage").rEvents.changeSpeedSizeRemote:InvokeServer("changeSize", 0)
                task.wait(1)
            end
        end)
    end
})

Window:SelectTab(1)
