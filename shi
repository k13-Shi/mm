local function NewTabButton(name, pos, targetTab)
    local btn = Instance.new("TextButton", K13_Sidebar)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = UDim2.new(0.05, 0, 0, pos)
    btn.BackgroundColor3 = Color3.fromRGB(45, 20, 80)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamMedium
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    local g = Instance.new("UIStroke", btn)
    g.Color = Color3.fromRGB(200, 100, 255)
    g.Thickness = 1.5
    btn.MouseButton1Click:Connect(function()
        for _, t in pairs(K13_Tabs) do t.Visible = false end
        targetTab.Visible = true
    end)
end

for name, frame in pairs(K13_Tabs) do
