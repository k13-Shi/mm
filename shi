local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "K13 MUSCLE MASTERS 🔥",
   LoadingTitle = "K13 Premium Script",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "K13Config"
   }
})

local Main = Window:CreateTab("Auto Farm", 4483362458)
local Eggs = Window:CreateTab("Auto Hatch", 4483362458)
local Misc = Window:CreateTab("Settings", 4483362458)

local LP = game:GetService("Players").LocalPlayer
local VIM = game:GetService("VirtualInputManager")

Main:CreateSection("Training & Rebirth")

Main:CreateToggle({
   Name = "Auto Use (Treadmill/Lift)",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
      getgenv().AutoFarm = Value
      task.spawn(function()
         while getgenv().AutoFarm do
            pcall(function()
                VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(0.05)
                VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                
                local rEvents = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents")
                if rEvents then
                    if rEvents:FindFirstChild("repRemote") then
                        rEvents.repRemote:FireServer("rep")
                    end
                end
            end)
            task.wait(0.1)
         end
      end)
   end,
})

Main:CreateToggle({
   Name = "Auto Rebirth",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      getgenv().AutoRebirth = Value
      task.spawn(function()
         while getgenv().AutoRebirth do
            pcall(function()
                local rEvents = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents")
                if rEvents and rEvents:FindFirstChild("rebirthRemote") then
                    rEvents.rebirthRemote:InvokeServer("rebirthRequest")
                end
            end)
            task.wait(2)
         end
      end)
   end,
})

Eggs:CreateSection("Egg Hatching")

local SelectedEgg = "Common"
Eggs:CreateDropdown({
   Name = "Select Egg",
   Options = {"Common", "Rare", "Epic", "Legendary", "Mythic"},
   CurrentOption = {"Common"},
   MultipleOptions = false,
   Flag = "EggRarity",
   Callback = function(Option)
      SelectedEgg = Option[1]
   end,
})

Eggs:CreateToggle({
   Name = "Auto Hatch",
   CurrentValue = false,
   Flag = "AutoHatch",
   Callback = function(Value)
      getgenv().AutoHatch = Value
      task.spawn(function()
         while getgenv().AutoHatch do
            pcall(function()
                local rEvents = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents")
                if rEvents and rEvents:FindFirstChild("eggRemote") then
                    rEvents.eggRemote:InvokeServer("openEgg", SelectedEgg)
                end
            end)
            task.wait(1.5)
         end
      end)
   end,
})

Eggs:CreateToggle({
   Name = "Auto Spin Wheel",
   CurrentValue = false,
   Flag = "AutoSpin",
   Callback = function(Value)
      getgenv().AutoSpin = Value
      task.spawn(function()
         while getgenv().AutoSpin do
            pcall(function()
                local rEvents = game:GetService("ReplicatedStorage"):FindFirstChild("rEvents")
                if rEvents and rEvents:FindFirstChild("wheelEvent") then
                    rEvents.wheelEvent:FireServer("spinWheel")
                end
            end)
            task.wait(5)
         end
      end)
   end,
})

Misc:CreateSection("Settings")

Misc:CreateToggle({
   Name = "Anti-AFK",
   CurrentValue = true,
   Flag = "AntiAFK",
   Callback = function(Value)
      getgenv().AntiAFK = Value
   end,
})

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)
