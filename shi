local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local displayName = Player.DisplayName

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "K13 | Muscle Masters",
   LoadingTitle = "K13 Executor",
   LoadingSubtitle = "by Sai Espinoza",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false
})

local isAutoPunch = false
local isAutoKillAll = false
local isTinyCombo = false
local isSticking = false
local selectedTarget = nil
local currentTargetConnection = nil

local function setCharSize(size)
    pcall(function() 
        ReplicatedStorage.RemotesEvent.SizeChanged:FireServer(size)
        local char = Player.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.BodyDepthScale.Value = size
                hum.BodyHeightScale.Value = size
                hum.BodyWidthScale.Value = size
                hum.HeadScale.Value = size
            end
        end
    end)
end

local MainTab = Window:CreateTab("Farm", 4483362458)
local KillTab = Window:CreateTab("Killing", 4483362458)

MainTab:CreateToggle({
   Name = "Auto Strength",
   CurrentValue = false,
   Callback = function(state) isAutoPunch = state end,
})

KillTab:CreateToggle({
   Name = "Auto Kill Everyone",
   CurrentValue = false,
   Callback = function(state) isAutoKillAll = state end,
})

KillTab:CreateToggle({
   Name = "Tiny Size Combo",
   CurrentValue = false,
   Callback = function(state)
      isTinyCombo = state
      if state then
         setCharSize(0.001)
         isAutoPunch = true
      else
         setCharSize(1)
      end
   end,
})

local playerList = {}
for _, plr in pairs(Players:GetPlayers()) do
    if plr ~= Player then table.insert(playerList, plr.DisplayName) end
end

local PlayerDropdown = KillTab:CreateDropdown({
   Name = "Select Target",
   Options = playerList,
   CurrentOption = "",
   Callback = function(selected)
      for _, plr in pairs(Players:GetPlayers()) do
         if plr.DisplayName == selected then
            selectedTarget = plr
            isSticking = true
            break
         end
      end
   end,
})

KillTab:CreateButton({
   Name = "Stop Teleport/Kill",
   Callback = function()
      isSticking = false
      selectedTarget = nil
   end,
})

RunService.RenderStepped:Connect(function()
    if isAutoPunch then
        ReplicatedStorage.RemotesEvent.PunchEvent:FireServer("RightHand")
    end

    if isAutoKillAll then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                if plr.Character.Humanoid.Health > 0 then
                    Player.Character.HumanoidRootPart.CFrame = plr.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
                    break
                end
            end
        end
    elseif isSticking and selectedTarget and selectedTarget.Character and selectedTarget.Character:FindFirstChild("HumanoidRootPart") then
        Player.Character.HumanoidRootPart.CFrame = selectedTarget.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
    end
end)

Rayfield:Notify({
   Title = "K13 Active",
   Content = "Auto Kill and Farm ready.",
   Duration = 5,
})
