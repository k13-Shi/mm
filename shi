local function NewButton(name, text)
    local f = Instance.new("Frame")
    f.Name = name.."_Frame"
    f.Parent = Main
    f.Size = UDim2.new(1, 0, 0, 28)
    f.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    f.BackgroundTransparency = 0.92
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
    
    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(0.8, 0, 1, 0)
    t.Position = UDim2.new(0.05, 0, 0, 0)
    t.BackgroundTransparency = 1
    t.Text = text
    t.TextColor3 = Color3.fromRGB(220, 220, 220)
    t.Font = Enum.Font.GothamMedium
    t.TextSize = 12
    t.TextXAlignment = Enum.TextXAlignment.Left

    local toggle = Instance.new("Frame", f)
    toggle.Size = UDim2.new(0, 18, 0, 18)
    toggle.Position = UDim2.new(0.93, 0, 0.5, 0)
    toggle.AnchorPoint = Vector2.new(0.5, 0.5)
    toggle.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 4)

    local check = Instance.new("Frame", toggle)
    check.Size = UDim2.new(0, 0, 0, 0)
    check.Position = UDim2.new(0.5, 0, 0.5, 0)
    check.AnchorPoint = Vector2.new(0.5, 0.5)
    check.BackgroundColor3 = Color3.fromRGB(180, 50, 255)
    Instance.new("UICorner", check).CornerRadius = UDim.new(0, 3)

    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    return btn, check
end

-- Create Buttons
local AutoRebirthButton, succus = NewButton("Rebirth", "Auto Rebirth")
local automuscleemp, succus_2 = NewButton("Farm", "Fast Auto Farm")
local autospinbutton, succus_3 = NewButton("Spin", "Auto Spin")
local autohatch_button, succus_hatch = NewButton("Hatch", "Auto Hatch Pets Lucky")
local antiafk_button, antiafk_succus = NewButton("AntiAFK", "Anti AFK System")
local extrascript_button, extrascript_succus = NewButton("Fly", "Active FLY Hack")

-- Scripts Logic
local isAuto, isAutolift, isapin, isHatch, antiAfkEnabled, extraScriptActive = false, false, false, false, false, false

local function animate(check, var)
    check:TweenSize(var and UDim2.new(0.7, 0, 0.7, 0) or UDim2.new(0, 0, 0, 0), "Out", "Back", 0.2)
end

AutoRebirthButton.Activated:Connect(function() isAuto = not isAuto animate(succus, isAuto) end)
automuscleemp.Activated:Connect(function() isAutolift = not isAutolift animate(succus_2, isAutolift) end)
autospinbutton.Activated:Connect(function() isapin = not isapin animate(succus_3, isapin) end)
autohatch_button.Activated:Connect(function() isHatch = not isHatch animate(succus_hatch, isHatch) end)

antiafk_button.Activated:Connect(function() 
    antiAfkEnabled = not antiAfkEnabled
    animate(antiafk_succus, antiAfkEnabled)
    if antiAfkEnabled then loadstring(game:HttpGet("https://pastebin.com/raw/r37Ct26d", true))() end
end)

extrascript_button.Activated:Connect(function() 
    extraScriptActive = not extraScriptActive
    animate(extrascript_succus, extraScriptActive)
    if extraScriptActive then loadstring(game:HttpGet("https://pastebin.com/raw/92uVadU5"))() end
end)

-- AUTO HATCH NEW LOGIC
task.spawn(function()
    local remotes = game:GetService("ReplicatedStorage").RemotesEvent
    
    -- Subukan natin ang iba't ibang posibleng Remote Names sa Muscle Masters
    local hatchRemote = remotes:FindFirstChild("HatchCrystal") or remotes:FindFirstChild("OpenEgg") or remotes:FindFirstChild("HatchEgg") or remotes:FindFirstChild("HatchCrystalFunction")
    
    while true do
        task.wait(0.3) -- Bahagyang bagal para hindi ma-kick sa spam
        
        if isAuto then remotes.RebirthEvent:FireServer() end
        if isapin then remotes.SpinFunction:InvokeServer() end
        
        -- Bagong Auto Hatch Logic para sa may Dropdown (Rarity)
        if isHatch and hatchRemote then
            -- Dahil may dropdown (Common to Mythic), susubukan natin ang default argument format
            -- Format: (Pangalan ng Egg, Bilang ng Hatch, Rarity/Mode)
            pcall(function()
                hatchRemote:InvokeServer("Pets Lucky", 1) -- Basic Mode
                hatchRemote:InvokeServer("Pets Lucky", "Common") -- Rarity Mode
            end)
        end
        
        if isAutolift then
            local machineuse = game.Players.LocalPlayer:WaitForChild("Machineuse")
            if machineuse.Value == nil then
                remotes.MachineActiveFunction:InvokeServer(game.Workspace.MachinesFolder["Bench Press Muscle Emperor"], true)
            else
                remotes.MachineActiveEvent:FireServer()
            end
        end
    end
end)

