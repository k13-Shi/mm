-- 1. HOME
local Home = Window:NewTab("K13 Home")
Home:NewSection("🟣 K13 PREMIUM VIOLET 🟣"):NewLabel("STATUS: ALL SYSTEMS FIXED")

-- 2. FARM (8-Pack Speed + Rebirth + Anti-AFK)
local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("Turbo Farming")

FarmSection:NewToggle("8-PACK SPEED (NO ANIM)", "Ultra Fast Reps", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool and LP.Character then LP.Character.Humanoid:EquipTool(tool) end
            local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
            if Remote then for i = 1, 25 do pcall(function() Remote:FireServer("rep") end) end end
            task.wait(0.001)
        end
    end)
end)

FarmSection:NewToggle("Instant Auto Rebirth", "No delay", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") end)
            task.wait(0.1)
        end
    end)
end)

FarmSection:NewToggle("Anti-AFK (No Kick)", "Stay 24/7", function(state)
    getgenv().AntiAFK = state
end)

-- 3. COMBAT (KILL ALL, VIEW, AUTO KILL - NO TELEPORT)
local Combat = Window:NewTab("Combat")
local CombatSection = Combat:NewSection("Player Kill & View (No TP)")

local function getPlayers()
    local p = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer then table.insert(p, v.Name) end
    end
    return p
end

local TargetDropdown = CombatSection:NewDropdown("Select Player", "Piliin ang target", getPlayers(), function(v)
    getgenv().SelectedPlayer = v
end)

CombatSection:NewButton("🔄 Refresh Player List", "Update names", function()
    TargetDropdown:Refresh(getPlayers())
end)

CombatSection:NewToggle("⚔️ Auto Kill Selected (No TP)", "Damage target without moving", function(state)
    getgenv().AutoKill = state
    task.spawn(function()
        while getgenv().AutoKill do
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character then
                pcall(function()
                    game.Players.LocalPlayer.muscleEvent:FireServer("punchClick", target.Character)
                    game.Players.LocalPlayer.muscleEvent:FireServer("rep", target.Character)
                end)
            end
            task.wait(0.01)
        end
    end)
end)

CombatSection:NewToggle("💀 KILL ALL (NO TELEPORT)", "Instant kill everyone", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character then
                    pcall(function()
                        game.Players.LocalPlayer.muscleEvent:FireServer("punchClick", v.Character)
                        game.Players.LocalPlayer.muscleEvent:FireServer("rep", v.Character)
                    end)
                end
            end
            task.wait(0.1)
        end
    end)
end)

CombatSection:NewToggle("👁️ View Player", "Spectate selected", function(state)
    getgenv().ViewPlayer = state
    task.spawn(function()
        while getgenv().ViewPlayer do
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character then
                workspace.CurrentCamera.CameraSubject = target.Character.Humanoid
            end
            task.wait(0.1)
        end
        workspace.CurrentCamera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
    end)
end)

CombatSection:NewToggle("☣️ Auto Toxic Message", "Chat L on kill", function(state)
    getgenv().AutoToxic = state
end)

-- 4. AUTO HATCH
local Pets = Window:NewTab("Auto Hatch")
local PetSection = Pets:NewSection("Egg Hatching")
PetSection:NewDropdown("Select Egg", "Complete List", {"Abyss Egg", "Legendary Egg", "Epic Egg", "Rare Egg", "Common Egg"}, function(v)
    getgenv().SelectedEgg = v
end)
PetSection:NewToggle("Start Auto Hatch (Triple)", "Hatch instantly", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            local egg = getgenv().SelectedEgg or "Abyss Egg"
            pcall(function() game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", egg, "triple") end)
            task.wait(0.1)
        end
    end)
end)

