-- Function for Buttons
local function NewButton(name, text)
    local f = Instance.new("Frame")
    f.Name = name.."_Frame"
    f.Parent = Main
    f.Size = UDim2.new(1, 0, 0, 30)
    f.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)
    
    local s = Instance.new("UIStroke", f)
    s.Thickness = 1
    s.Color = Color3.fromRGB(60, 60, 80)

    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(0.8, 0, 1, 0)
    t.Position = UDim2.new(0.05, 0, 0, 0)
    t.BackgroundTransparency = 1
    t.Text = text:upper()
    t.TextColor3 = Color3.fromRGB(180, 180, 180)
    t.Font = Enum.Font.Code
    t.TextSize = 13
    t.TextXAlignment = Enum.TextXAlignment.Left

    local status = Instance.new("Frame", f)
    status.Size = UDim2.new(0, 4, 0, 15)
    status.Position = UDim2.new(0.95, 0, 0.5, 0)
    status.AnchorPoint = Vector2.new(0.5, 0.5)
    status.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    status.BorderSizePixel = 0

    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    return btn, status, s
end

-- Create Buttons
local AutoRebirthButton, st1, str1 = NewButton("Rebirth", "Auto Rebirth")
local automuscleemp, st2, str2 = NewButton("Farm", "Fast Auto Farm")
local autospinbutton, st3, str3 = NewButton("Spin", "Auto Spin")
local antiafk_button, st4, str4 = NewButton("AntiAFK", "Anti AFK System")
local extrascript_button, st5, str5 = NewButton("Fly", "Active FLY Script")

-- Logic
local isAuto, isAutolift, isapin, antiAfkEnabled, extraScriptActive = false, false, false, false, false

local function toggle(var, status, stroke)
    var = not var
    if var then
        status.BackgroundColor3 = Color3.fromRGB(170, 0, 255)
        stroke.Color = Color3.fromRGB(170, 0, 255)
    else
        status.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        stroke.Color = Color3.fromRGB(60, 60, 80)
    end
    return var
end

AutoRebirthButton.Activated:Connect(function() isAuto = toggle(isAuto, st1, str1) end)
automuscleemp.Activated:Connect(function() isAutolift = toggle(isAutolift, st2, str2) end)
autospinbutton.Activated:Connect(function() isapin = toggle(isapin, st3, str3) end)
antiafk_button.Activated:Connect(function() 
    antiAfkEnabled = toggle(antiAfkEnabled, st4, str4)
    if antiAfkEnabled then loadstring(game:HttpGet("https://pastebin.com/raw/r37Ct26d", true))() end
end)
extrascript_button.Activated:Connect(function() 
    extraScriptActive = toggle(extraScriptActive, st5, str5)
    if extraScriptActive then loadstring(game:HttpGet("https://pastebin.com/raw/92uVadU5"))() end
end)

-- Main Loop
task.spawn(function()
    local remotes = game:GetService("ReplicatedStorage").RemotesEvent
    while true do
        task.wait(0.1)
        if isAuto then remotes.RebirthEvent:FireServer() end
        if isapin then remotes.SpinFunction:InvokeServer() end
        if isAutolift then
            local machineuse = game.Players.LocalPlayer:WaitForChild("Machineuse")
            if machineuse.Value == nil then
                remotes.MachineActiveFunction:InvokeServer(game.Workspace.MachinesFolder["Bench Press Muscle Emperor"], true)
            else
                remotes.MachineActiveEvent:FireServer()
            end
        end
    end
end)

