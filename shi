-- Main Execution Loop
task.spawn(function()
    while task.wait(0.1) do
        if active.Spin then pcall(function() game.ReplicatedStorage.RemotesEvent.SpinFunction:InvokeServer() end) end
        if active.Rebirth then pcall(function() game.ReplicatedStorage.RemotesEvent.RebirthEvent:FireServer() end) end
        if active.Farm then
            pcall(function()
                local machineuse = game.Players.LocalPlayer:WaitForChild("Machineuse")
                if machineuse.Value == nil then
                    game.ReplicatedStorage.RemotesEvent.MachineActiveFunction:InvokeServer(game.Workspace.MachinesFolder["Bench Press Muscle Emperor"], true)
                else
                    game.ReplicatedStorage.RemotesEvent.MachineActiveEvent:FireServer()
                end
            end)
        end
    end
end)
