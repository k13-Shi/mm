-- Helper Function para sa Buttons para iwas error sa list
local function CreateButtonFrame(name, text, parent)
    local frame = Instance.new("Frame")
    frame.Name = name
    frame.Parent = parent
    frame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    frame.Size = UDim2.new(0.85, 0, 0.15, 0) -- Mas maliit na height
    frame.ZIndex = 3
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0.2, 0)
    corner.Parent = frame

    local title = Instance.new("TextLabel")
    title.Parent = frame
    title.BackgroundTransparency = 1
    title.Position = UDim2.new(0.4, 0, 0.5, 0)
    title.Size = UDim2.new(0.7, 0, 0.8, 0)
    title.AnchorPoint = Vector2.new(0.5, 0.5)
    title.Font = Enum.Font.DenkOne
    title.Text = text
    title.TextColor3 = Color3.fromRGB(230, 230, 230)
    title.TextScaled = true
    title.ZIndex = 6

    local toggleFrame = Instance.new("Frame")
    toggleFrame.Parent = frame
    toggleFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    toggleFrame.Position = UDim2.new(0.9, 0, 0.5, 0)
    toggleFrame.Size = UDim2.new(0.18, 0, 0.8, 0)
    toggleFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    toggleFrame.ZIndex = 4
    
    local tCorner = Instance.new("UICorner")
    tCorner.Parent = toggleFrame

    local checkIcon = Instance.new("ImageLabel")
    checkIcon.Parent = toggleFrame
    checkIcon.BackgroundTransparency = 1
    checkIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
    checkIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    checkIcon.Size = UDim2.new(0, 0, 0, 0) -- Hidden initially
    checkIcon.Image = "rbxassetid://131708009919712"
    checkIcon.ImageColor3 = Color3.fromRGB(180, 0, 255)
    checkIcon.ZIndex = 5

    local btn = Instance.new("TextButton")
    btn.Parent = toggleFrame
    btn.BackgroundTransparency = 1
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Text = ""
    btn.ZIndex = 20

    return btn, checkIcon
end

