local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("K13 MUSCLE MASTERS 🔥", "DarkTheme")

local Main = Window:NewTab("K13 Home")
local MainSection = Main:NewSection("K13 PREMIUM - VIOLET EDITION")

local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("8-Pack Speed Farm")

FarmSection:NewToggle("ULTRA FAST LIFT (8-PACK MODE)", "Pinakamabilis na Reps sa Muscle Masters", function(state)
    getgenv().AutoFarm = state
    if state then
        -- Multi-Threaded Spam (10 Threads para sa Maximum Speed)
        for i = 1, 10 do
            task.spawn(function()
                local LP = game.Players.LocalPlayer
                local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
                
                while getgenv().AutoFarm do
                    if Remote then
                        if Remote.ClassName == "RemoteEvent" then
                            Remote:FireServer("rep")
                        else
                            Remote:InvokeServer("rep")
                        end
                    end
                    -- No Wait / Minimal Delay for 8-pack speed
                    task.wait() 
                end
            end)
        end
        
        -- Virtual Clicker Thread
        task.spawn(function()
            local VIM = game:GetService("VirtualInputManager")
            while getgenv().AutoFarm do
                VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                task.wait()
            end
        end)
    end
end)

FarmSection:NewToggle("Instant Rebirth", "Automatic Rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            task.wait(0.01)
        end
    end)
end)

local Misc = Window:NewTab("Misc")
local MiscSection = Misc:NewSection("Abyss & Utilities")

MiscSection:NewToggle("Auto Hatch Abyss (Fast)", "Spam Hatch Abyss Eggs", function(state)
    getgenv().AutoHatch = state
    task.spawn(function()
        while getgenv().AutoHatch do
            game:GetService("ReplicatedStorage").rEvents.petEvent:FireServer("openEgg", "Abyss Egg", "triple")
            task.wait(0.01)
        end
    end)
end)

MiscSection:NewToggle("Anti-AFK", "No Disconnect", function(state)
    getgenv().AntiAFK = state
end)

game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if getgenv().AntiAFK then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    end
end)

