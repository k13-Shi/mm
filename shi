task.spawn(function()
    while task.wait(0.1) do
        if flg.Farm then
            pcall(function()
                local m = workspace.MachinesFolder:FindFirstChild("Bench Press Muscle Emperor")
                if m and LP.Character:FindFirstChild("HumanoidRootPart") then
                    LP.Character.HumanoidRootPart.CFrame = m.InteractionPart.CFrame
                    ReplicatedStorage.RemotesEvent.MachineActiveFunction:InvokeServer(m, true)
                    ReplicatedStorage.RemotesEvent.MachineActiveEvent:FireServer()
                end
            end)
        end
        if flg.Reb then pcall(function() ReplicatedStorage.RemotesEvent.RebirthEvent:FireServer() end) end
        if LP.Character and LP.Character:FindFirstChild("Humanoid") then
            LP.Character.Humanoid.WalkSpeed = flg.Speed
        end
    end
end)

