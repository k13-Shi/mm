HomeSection:NewLabel("STATUS: ALL SYSTEMS OPERATIONAL")
HomeSection:NewLabel("Toggle Key: RightControl")

-- [ TAB 2: FARM ]
local Farm = Window:NewTab("Farm")
local FarmSection = Farm:NewSection("8-Pack Turbo Farm")

FarmSection:NewToggle("8-PACK SPEED (STABLE)", "Ultra Fast Reps + Auto Equip", function(state)
    getgenv().AutoFarm = state
    task.spawn(function()
        while getgenv().AutoFarm do
            local LP = game.Players.LocalPlayer
            local tool = LP.Backpack:FindFirstChildOfClass("Tool") or LP.Character:FindFirstChildOfClass("Tool")
            if tool and LP.Character then LP.Character.Humanoid:EquipTool(tool) end
            
            local Remote = LP:FindFirstChild("muscleEvent") or (game:GetService("ReplicatedStorage"):FindFirstChild("rEvents") and game:GetService("ReplicatedStorage").rEvents:FindFirstChild("repRemote"))
            if Remote then
                for i = 1, 25 do pcall(function() Remote:FireServer("rep") end) end
            end
            task.wait(0.001)
        end
    end)
end)

FarmSection:NewToggle("Instant Auto Rebirth", "No delay rebirth", function(state)
    getgenv().AutoRebirth = state
    task.spawn(function()
        while getgenv().AutoRebirth do
            pcall(function() game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest") end)
            task.wait(0.1)
        end
    end)
end)

FarmSection:NewToggle("Anti-AFK (No Kick)", "Stay online 24/7", function(state)
    getgenv().AntiAFK = state
end)

-- [ TAB 3: COMBAT ]
local Combat = Window:NewTab("Combat")
local CombatSection = Combat:NewSection("Kill & View (No Teleport)")

local function getPlayers()
    local p = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer then table.insert(p, v.Name) end
    end
    return p
end

local TargetDropdown = CombatSection:NewDropdown("Select Player", "Target name", getPlayers(), function(v)
    getgenv().SelectedPlayer = v
end)

CombatSection:NewButton("🔄 Refresh Player List", "Update names", function()
    TargetDropdown:Refresh(getPlayers())
end)

CombatSection:NewToggle("⚔️ Auto Kill Selected (No TP)", "Damage target without moving", function(state)
    getgenv().AutoKill = state
    task.spawn(function()
        while getgenv().AutoKill do
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character then
                pcall(function()
                    game.Players.LocalPlayer.muscleEvent:FireServer("punchClick", target.Character)
                    game.Players.LocalPlayer.muscleEvent:FireServer("rep", target.Character)
                end)
            end
            task.wait(0.01)
        end
    end)
end)

CombatSection:NewToggle("💀 KILL ALL (NO TELEPORT)", "Instant kill everyone", function(state)
    getgenv().KillAll = state
    task.spawn(function()
        while getgenv().KillAll do
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character then
                    pcall(function()
                        game.Players.LocalPlayer.muscleEvent:FireServer("punchClick", v.Character)
                        game.Players.LocalPlayer.muscleEvent:FireServer("rep", v.Character)
                    end)
                end
            end
            task.wait(0.1)
        end
    end)
end)

CombatSection:NewToggle("👁️ View Player", "Spectate target", function(state)
    getgenv().ViewPlayer = state
    task.spawn(function()
        while getgenv().ViewPlayer do
            local target = game.Players:FindFirstChild(getgenv().SelectedPlayer)
            if target and target.Character then
                workspace.CurrentCamera.CameraSubject = target.Character.Humanoid
            end
            task.wait(0.1)
        end
        workspace.CurrentCamera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
    end)
end)

CombatSection:NewToggle("☣️ Auto Toxic Message", "Chat toxic lines", function(state)
    getgenv().AutoToxic = state
end)

