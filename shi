-- [[ K13 PURPLE GLOW - FAST AUTO FARM UPDATE ]]

-- Assets & Variables for the new button
local MuscleEmpActive = false
local MuscleEmpRemote = game.ReplicatedStorage.RemotesEvent.MachineActiveFunction
local MuscleEmpEvent = game.ReplicatedStorage.RemotesEvent.MachineActiveEvent

-- 1. Create the Main Button Frame (autoliftmuscleemp)
local autoliftmuscleemp = Instance.new("Frame")
autoliftmuscleemp.Name = "autoliftmuscleemp"
autoliftmuscleemp.Parent = K13_Tabs.Main -- Nilagay ko sa Main Tab ng K13 UI mo
autoliftmuscleemp.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
autoliftmuscleemp.BorderSizePixel = 0
autoliftmuscleemp.Size = UDim2.new(0.95, 0, 0, 55) -- Adjusted size para sa K13 Layout
autoliftmuscleemp.ZIndex = 3

local UICorner1_3 = Instance.new("UICorner", autoliftmuscleemp)
UICorner1_3.CornerRadius = UDim.new(0, 10)

-- Purple Glow for the button
local PurpleGlow = Instance.new("UIStroke", autoliftmuscleemp)
PurpleGlow.Color = Color3.fromRGB(150, 0, 255)
PurpleGlow.Thickness = 1.5

-- 2. Title Text (titlem_2)
local titlem_2 = Instance.new("TextLabel")
titlem_2.Name = "titlem"
titlem_2.Parent = autoliftmuscleemp
titlem_2.BackgroundTransparency = 1.000
titlem_2.Position = UDim2.new(0.05, 0, 0.5, -15)
titlem_2.Size = UDim2.new(0.6, 0, 0, 30)
titlem_2.ZIndex = 6
titlem_2.Font = Enum.Font.GothamBold
titlem_2.Text = "FAST AUTO FARM"
titlem_2.TextColor3 = Color3.fromRGB(255, 255, 255)
titlem_2.TextScaled = true
titlem_2.TextXAlignment = Enum.TextXAlignment.Left

-- 3. Toggle Container (muyscleemp)
local muyscleemp = Instance.new("Frame")
muyscleemp.Name = "muyscleemp"
muyscleemp.Parent = autoliftmuscleemp
muyscleemp.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
muyscleemp.Position = UDim2.new(0.82, 0, 0.5, -15)
muyscleemp.Size = UDim2.new(0, 30, 0, 30)
muyscleemp.ZIndex = 4
Instance.new("UICorner", muyscleemp).CornerRadius = UDim.new(0, 8)

-- 4. Success Indicator Image (succus_2)
local succus_2 = Instance.new("ImageLabel")
succus_2.Name = "succus_2"
succus_2.Parent = muyscleemp
succus_2.AnchorPoint = Vector2.new(0.5, 0.5)
succus_2.BackgroundTransparency = 1.000
succus_2.Position = UDim2.new(0.5, 0, 0.5, 0)
succus_2.ZIndex = 5
succus_2.Image = "rbxassetid://131708009919712" -- Yung checkmark/indicator mo
succus_2.ImageColor3 = Color3.fromRGB(150, 0, 255) -- Ginawa kong purple!
succus_2.Size = UDim2.new(0, 0, 0, 0) -- Hidden by default

-- 5. The Actual Click Button (automuscleemp)
local automuscleemp = Instance.new("TextButton")
automuscleemp.Name = "automuscleemp"
automuscleemp.Parent = muyscleemp
automuscleemp.BackgroundTransparency = 1.000
automuscleemp.Size = UDim2.new(1, 0, 1, 0)
automuscleemp.ZIndex = 20
automuscleemp.Text = ""

-- Logic for Fast Farm Toggle
automuscleemp.MouseButton1Click:Connect(function()
    MuscleEmpActive = not MuscleEmpActive
    
    -- Animation ng indicator
    if MuscleEmpActive then
        succus_2:TweenSize(UDim2.new(0.7, 0, 0.7, 0), "Out", "Back", 0.2)
        PurpleGlow.Thickness = 3 -- Mas makapal na glow pag ON
    else
        succus_2:TweenSize(UDim2.new(0, 0, 0, 0), "Out", "Quad", 0.2)
        PurpleGlow.Thickness = 1.5
    end
end)

-- High Speed Farm Loop (Anti-Kick)
task.spawn(function()
    while task.wait(0.15) do -- Speed balance para di ma-kick
        if MuscleEmpActive then
            pcall(function()
                local machine = game.Workspace.MachinesFolder["Bench Press Muscle Emperor"]
                MuscleEmpRemote:InvokeServer(machine, true)
                task.wait(0.05)
                MuscleEmpEvent:FireServer()
            end)
        end
    end
end)
