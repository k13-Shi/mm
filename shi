-- SCRIPT LOGIC (Keep original functions)
local isAuto, isAutolift, isapin, antiAfkEnabled, extraScriptActive = false, false, false, false, false

local function toggle(btn, check, var)
    var = not var
    check:TweenSize(var and UDim2.new(0.7, 0, 0.7, 0) or UDim2.new(0, 0, 0, 0), "Out", "Back", 0.2)
    return var
end

AutoRebirthButton.Activated:Connect(function() isAuto = toggle(AutoRebirthButton, succus, isAuto) end)
automuscleemp.Activated:Connect(function() isAutolift = toggle(automuscleemp, succus_2, isAutolift) end)
autospinbutton.Activated:Connect(function() isapin = toggle(autospinbutton, succus_3, isapin) end)

antiafk_button.Activated:Connect(function() 
    antiAfkEnabled = toggle(antiafk_button, antiafk_succus, antiAfkEnabled)
    if antiAfkEnabled then loadstring(game:HttpGet("https://pastebin.com/raw/r37Ct26d", true))() end
end)

extrascript_button.Activated:Connect(function() 
    extraScriptActive = toggle(extrascript_button, extrascript_succus, extraScriptActive)
    if extraScriptActive then loadstring(game:HttpGet("https://pastebin.com/raw/92uVadU5"))() end
end)

task.spawn(function()
    while true do
        task.wait(0.1)
        if isapin then game.ReplicatedStorage.RemotesEvent.SpinFunction:InvokeServer() end
        if isAuto then game.ReplicatedStorage.RemotesEvent.RebirthEvent:FireServer() end
        if isAutolift then
            local machineuse = game.Players.LocalPlayer:WaitForChild("Machineuse")
            if machineuse.Value == nil then
                game.ReplicatedStorage.RemotesEvent.MachineActiveFunction:InvokeServer(game.Workspace.MachinesFolder["Bench Press Muscle Emperor"], true)
            else
                game.ReplicatedStorage.RemotesEvent.MachineActiveEvent:FireServer()
            end
        end
    end
end)
