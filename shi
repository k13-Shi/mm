-- Function to create Modern Buttons
local function NewButton(name, text)
    local f = Instance.new("Frame")
    f.Name = name.."_Frame"
    f.Parent = Main
    f.Size = UDim2.new(1, 0, 0, 32) -- Slimmer buttons
    f.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    f.BackgroundTransparency = 0.92
    
    local c = Instance.new("UICorner", f)
    c.CornerRadius = UDim.new(0, 6)
    
    local s = Instance.new("UIStroke", f)
    s.Thickness = 1
    s.Color = Color3.fromRGB(100, 100, 100)
    s.Transparency = 0.5

    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(0.8, 0, 1, 0)
    t.Position = UDim2.new(0.05, 0, 0, 0)
    t.BackgroundTransparency = 1
    t.Text = text
    t.TextColor3 = Color3.fromRGB(220, 220, 220)
    t.Font = Enum.Font.GothamMedium
    t.TextSize = 14
    t.TextXAlignment = Enum.TextXAlignment.Left

    local toggle = Instance.new("Frame", f)
    toggle.Size = UDim2.new(0, 20, 0, 20)
    toggle.Position = UDim2.new(0.93, 0, 0.5, 0)
    toggle.AnchorPoint = Vector2.new(0.5, 0.5)
    toggle.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 4)

    local check = Instance.new("Frame", toggle)
    check.Size = UDim2.new(0, 0, 0, 0)
    check.Position = UDim2.new(0.5, 0, 0.5, 0)
    check.AnchorPoint = Vector2.new(0.5, 0.5)
    check.BackgroundColor3 = Color3.fromRGB(180, 50, 255) -- Purple Check
    Instance.new("UICorner", check).CornerRadius = UDim.new(0, 3)

    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    return btn, check
end

