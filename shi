local Pets = Window:NewTab("Auto Hatch")
local PetSection = Pets:NewSection("Complete Egg List")

PetSection:NewDropdown("Select Egg", "Pili ka dito", {"Abyss Egg", "Legendary Egg", "Epic Egg", "Rare Egg", "Common Egg"}, function(v)
